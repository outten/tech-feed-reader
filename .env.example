# Tech Feed Reader — environment variables. Copy to .env and fill in.
# .env is gitignored; .env.example is checked in as a template.

# ---- Phase A1 (consumer auth) -----------------------------------------------
# Long random hex for the signed-cookie session store. Generate fresh:
#   ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
# Rotating this signs everyone out + invalidates any unused recovery
# codes (the hash key changes). Don't do that lightly.
SESSION_SECRET=replace_with_64_byte_hex

# WebAuthn relying-party config. RP_ID is the bare domain (no scheme,
# no port); ORIGIN is the full origin including scheme + port. In dev
# both default to localhost / http://localhost:4567 if unset.
WEBAUTHN_RP_NAME=Tech Feed Reader
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:4567

# ---- LLM rate limiting ------------------------------------------------------
# Cost containment on the four user-facing Claude routes (/triage, /chat,
# /article/:uid/summarize/llm, /digests/:id/summarize). LLM_ENABLED=false
# disables all four without a redeploy. The token + cost ceilings stop a
# stampede from draining the API key. See app/llm_guard.rb.
LLM_ENABLED=true
LLM_USER_DAILY_TOKEN_BUDGET=200000
LLM_GLOBAL_HOURLY_TOKEN_BUDGET=2000000
LLM_GLOBAL_HOURLY_COST_BUDGET=5.00

# ---- Observability ----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
