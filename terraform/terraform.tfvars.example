# Copy to terraform.tfvars (gitignored) and fill in. Don't commit
# terraform.tfvars — it contains the API tokens and would let anyone
# with read access to the repo provision/destroy your infrastructure.

# ---- DigitalOcean -----------------------------------------------------------
# Dashboard → API → Generate New Token (read + write scopes).
do_token = "dop_v1_REPLACE_ME"

# Dashboard → API → Spaces Keys → Generate New Key. Both halves needed.
do_spaces_access_id  = "REPLACE_ME"
do_spaces_secret_key = "REPLACE_ME"

# ---- Domain + droplet -------------------------------------------------------
# `domain` is the apex zone hosted in DO DNS. The registrar's NS
# records must already point at ns{1,2,3}.digitalocean.com AND the
# zone must already exist in the DO control panel (Networking →
# Domains). Terraform uses a `data` block to reference it — won't
# create or modify the zone itself, only the A record for the
# subdomain below.
#
# `app_subdomain` is where this app serves. Default `feeder` →
# https://feeder.tmoneystuff.com. Leave the apex free for other apps
# the user plans to deploy on the same zone.
domain              = "tmoneystuff.com"
app_subdomain       = "feeder"
region              = "nyc3"
droplet_size        = "s-1vcpu-2gb"
ssh_key_fingerprint = "REPLACE_ME"  # ssh-keygen -lf ~/.ssh/id_ed25519.pub | awk '{print $2}'

# Your public IP / CIDRs for SSH access. Find via: curl ifconfig.me
# Append /32 to make it a single-IP rule. Add additional entries if
# you SSH from multiple locations (home, office, etc).
allowed_ssh_cidrs = ["203.0.113.42/32"]

# Optional override (default is "tech-feed-reader-backups").
# backups_bucket_name = "tfr-backups-prod"
