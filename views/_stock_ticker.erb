<%# Stock ticker bar — included on the dashboard when the user
    follows at least one stock symbol. Reads from @stock_quotes
    (cached DB data, no API calls on render). %>
<% if @stock_quotes && @stock_quotes.any? %>
  <section class="stock-ticker-section" aria-label="Stock ticker">
    <div class="stock-ticker-bar">
      <div class="stock-ticker-track">
        <% @stock_quotes.each do |q| %>
          <a href="/stocks/<%= h(q['symbol']) %>" class="stock-ticker-item" title="<%= h(q['name'] || q['symbol']) %>">
            <span class="stock-ticker-symbol"><%= h(q['symbol']) %></span>
            <% if q['price'] %>
              <span class="stock-ticker-price"><%= format_price(q['price']) %></span>
              <span class="stock-ticker-change <%= q['change'].to_f >= 0 ? 'positive' : 'negative' %>">
                <%= q['change'].to_f >= 0 ? '▲' : '▼' %>
                <%= format_pct(q['change_pct']) %>
              </span>
            <% end %>
          </a>
        <% end %>
        <%# Duplicate for seamless scroll loop %>
        <% @stock_quotes.each do |q| %>
          <a href="/stocks/<%= h(q['symbol']) %>" class="stock-ticker-item" aria-hidden="true" tabindex="-1"
             title="<%= h(q['name'] || q['symbol']) %>">
            <span class="stock-ticker-symbol"><%= h(q['symbol']) %></span>
            <% if q['price'] %>
              <span class="stock-ticker-price"><%= format_price(q['price']) %></span>
              <span class="stock-ticker-change <%= q['change'].to_f >= 0 ? 'positive' : 'negative' %>">
                <%= q['change'].to_f >= 0 ? '▲' : '▼' %>
                <%= format_pct(q['change_pct']) %>
              </span>
            <% end %>
          </a>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
