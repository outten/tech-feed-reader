<%# Stock quotes grid — rendered in the layout on every page for signed-in
    users. Shows the user's followed symbols then the major world indices.
    Reads cached DB rows, no API calls on render. %>
<% quotes = ticker_quotes %>
<% if quotes.any? %>
  <div class="stock-grid">
    <% quotes.each do |q| %>
      <% chg = q['change'].to_f %>
      <a href="/stocks/<%= h(q['symbol']) %>" class="stock-cell">
        <span class="stock-cell-symbol"><%= h(q['symbol']) %></span>
        <% if q['price'] %>
          <span class="stock-cell-price"><%= format_price(q['price']) %></span>
          <span class="stock-cell-change <%= chg >= 0 ? 'positive' : 'negative' %>">
            <%= chg >= 0 ? '▲' : '▼' %> <%= format_pct(q['change_pct']) %>
          </span>
        <% end %>
      </a>
    <% end %>
  </div>
<% end %>
