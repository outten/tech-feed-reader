<div class="page-header">
  <div>
    <h2>Admin</h2>
    <p class="subtitle">System overview, counts, database, integrations.</p>
  </div>
</div>

<% if @degraded %>
  <div class="degradation-banner">
    <span class="banner-icon">⚠</span>
    <span><strong>Feeds are systematically failing.</strong> See <a class="banner-link" href="/admin/health">/admin/health</a>.</span>
  </div>
<% end %>

<section class="benchmark-section">
  <h3>Content</h3>
  <div class="stat-cards">
    <div class="summary-card">
      <span class="summary-label">Feeds</span>
      <span class="summary-value"><%= @counts[:feeds] %></span>
      <span class="summary-sub">
        <%= @due_now %> due to refresh now
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Articles</span>
      <span class="summary-value"><%= @counts[:articles] %></span>
      <span class="summary-sub">
        <%= @counts[:unread] %> unread &middot; <%= @counts[:bookmarked] %> bookmarked
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Summaries</span>
      <span class="summary-value"><%= @counts[:summaries] %></span>
      <span class="summary-sub">
        <%= @counts[:summaries_llm] %> with LLM
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Tags</span>
      <span class="summary-value"><%= @counts[:tags] %></span>
      <span class="summary-sub">
        <%= @counts[:article_tags] %> article tags applied
      </span>
    </div>
  </div>
</section>

<section class="benchmark-section">
  <h3>Database</h3>
  <table class="data-table">
    <tbody>
      <tr><td>Path</td>          <td class="mono"><%= h(@db_path) %></td></tr>
      <tr><td>Size on disk</td>  <td class="num mono"><%= number_to_human_size(@db_bytes) %></td></tr>
      <tr><td>FTS5 articles</td> <td class="num"><%= @counts[:articles] %> rows indexed</td></tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>Integrations</h3>
  <table class="data-table">
    <tbody>
      <tr>
        <td>Claude (LLM summarizer)</td>
        <td>
          <% if @claude_available %>
            <span class="badge bookmarked">enabled</span>
            using <code>claude-opus-4-7</code>
          <% else %>
            <span class="badge">disabled</span>
            set <code>ANTHROPIC_API_KEY</code> in <code>.credentials</code>
          <% end %>
        </td>
      </tr>
      <tr>
        <td>HealthRegistry</td>
        <td>
          <% if @health_enabled %>
            <span class="badge bookmarked">enabled</span>
            <%= @health_observations %> observation<%= 's' unless @health_observations == 1 %> in the buffer
          <% else %>
            <span class="badge">no-op</span>
            set <code>HEALTH_REGISTRY=1</code> to enable
          <% end %>
        </td>
      </tr>
      <tr>
        <td>Sidekiq (background refresh)</td>
        <td>
          <span class="badge">not yet wired</span>
          ships in TODO-029 — Web UI will mount at <a href="/admin/sidekiq">/admin/sidekiq</a>
        </td>
      </tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>System</h3>
  <table class="data-table">
    <tbody>
      <tr><td>Ruby</td>           <td class="mono"><%= h(RUBY_VERSION) %></td></tr>
      <tr><td>Platform</td>       <td class="mono"><%= h(RUBY_PLATFORM) %></td></tr>
      <tr><td>RACK_ENV</td>       <td class="mono"><%= h(ENV['RACK_ENV'] || 'development') %></td></tr>
      <tr><td>LOG_LEVEL</td>      <td class="mono"><%= h(ENV['LOG_LEVEL'] || '(default)') %></td></tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>Sub-pages</h3>
  <ul>
    <li><a href="/admin/cache">/admin/cache</a> — per-feed cache age + manual refresh</li>
    <li><a href="/admin/health">/admin/health</a> — feed-fetch observation history</li>
    <li><a href="/admin/sidekiq">/admin/sidekiq</a> — background-job UI <em class="muted">(after TODO-029)</em></li>
  </ul>
</section>
