<div class="page-header">
  <div>
    <h2>Admin</h2>
    <p class="subtitle">System overview, counts, database, integrations.</p>
  </div>
</div>

<% if @degraded %>
  <div class="degradation-banner">
    <span class="banner-icon">⚠</span>
    <span><strong>Feeds are systematically failing.</strong> See <a class="banner-link" href="/admin/health">/admin/health</a>.</span>
  </div>
<% end %>

<section class="benchmark-section">
  <h3>Content</h3>
  <div class="stat-cards">
    <div class="summary-card">
      <span class="summary-label">Feeds</span>
      <span class="summary-value"><%= @counts[:feeds] %></span>
      <span class="summary-sub">
        <%= @due_now %> due to refresh now
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Articles</span>
      <span class="summary-value"><%= @counts[:articles] %></span>
      <span class="summary-sub">
        <%= @counts[:unread] %> unread &middot; <%= @counts[:bookmarked] %> bookmarked
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Summaries</span>
      <span class="summary-value"><%= @counts[:summaries] %></span>
      <span class="summary-sub">
        <%= @counts[:summaries_llm] %> with LLM
      </span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Tags</span>
      <span class="summary-value"><%= @counts[:tags] %></span>
      <span class="summary-sub">
        <%= @counts[:article_tags] %> article tags applied
      </span>
    </div>
  </div>
</section>

<section class="benchmark-section">
  <h3>Database</h3>
  <table class="data-table">
    <tbody>
      <tr><td>Path</td>          <td class="mono"><%= h(@db_path) %></td></tr>
      <tr><td>Size on disk</td>  <td class="num mono"><%= number_to_human_size(@db_bytes) %></td></tr>
      <tr><td>FTS5 articles</td> <td class="num"><%= @counts[:articles] %> rows indexed</td></tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>Integrations</h3>
  <table class="data-table">
    <tbody>
      <tr>
        <td>Claude (LLM summarizer)</td>
        <td>
          <% if @claude_available %>
            <span class="badge bookmarked">enabled</span>
            using <code>claude-opus-4-7</code>
          <% else %>
            <span class="badge">disabled</span>
            set <code>ANTHROPIC_API_KEY</code> in <code>.credentials</code>
          <% end %>
        </td>
      </tr>
      <tr>
        <td>HealthRegistry</td>
        <td>
          <% if @health_enabled %>
            <span class="badge bookmarked">enabled</span>
            <%= @health_observations %> observation<%= 's' unless @health_observations == 1 %> in the buffer
          <% else %>
            <span class="badge">no-op</span>
            set <code>HEALTH_REGISTRY=1</code> to enable
          <% end %>
        </td>
      </tr>
      <tr>
        <td>OpenTelemetry tracing</td>
        <td>
          <% if @tracing_enabled %>
            <span class="badge bookmarked">enabled</span>
            <%= @tracing_spans %> span<%= 's' unless @tracing_spans == 1 %> in the buffer &middot;
            <% if @tracing_otlp %>
              OTLP &rarr; <code><%= h(@tracing_endpoint) %></code>
            <% else %>
              in-memory only &middot; set <code>OTEL_EXPORTER_OTLP_ENDPOINT</code> for OTLP export
            <% end %>
            &middot; <a href="/admin/traces">browse traces</a>
          <% else %>
            <span class="badge">no-op</span>
            (disabled in test env)
          <% end %>
        </td>
      </tr>
      <tr>
        <td>Sidekiq (background refresh)</td>
        <td>
          <% if @sidekiq[:ok] %>
            <% if @sidekiq[:workers] > 0 %>
              <span class="badge bookmarked">enabled</span>
              <%= @sidekiq[:workers] %> worker<%= 's' unless @sidekiq[:workers] == 1 %> &middot;
              <%= @sidekiq[:enqueued] %> queued &middot;
              <%= @sidekiq[:processed] %> processed lifetime
            <% else %>
              <span class="badge">redis up, no worker running</span>
              start with <code>make sidekiq</code> &middot;
              <%= @sidekiq[:enqueued] %> waiting in queue
            <% end %>
            &middot; <a href="/admin/sidekiq">open Web UI</a>
          <% else %>
            <span class="badge">redis unreachable</span>
            <code><%= h(@sidekiq[:error]) %></code>
          <% end %>
        </td>
      </tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>System</h3>
  <table class="data-table">
    <tbody>
      <tr><td>Ruby</td>           <td class="mono"><%= h(RUBY_VERSION) %></td></tr>
      <tr><td>Platform</td>       <td class="mono"><%= h(RUBY_PLATFORM) %></td></tr>
      <tr><td>RACK_ENV</td>       <td class="mono"><%= h(ENV['RACK_ENV'] || 'development') %></td></tr>
      <tr><td>LOG_LEVEL</td>      <td class="mono"><%= h(ENV['LOG_LEVEL'] || '(default)') %></td></tr>
      <tr><td>Version (git)</td>  <td class="mono"><%= h(AppVersion::GIT_SHA) %></td></tr>
      <tr><td>Started at</td>     <td class="mono"><%= h(AppVersion::STARTED_AT.iso8601) %> &middot; <%= AppVersion.uptime_seconds %>s uptime</td></tr>
    </tbody>
  </table>
</section>

<section class="benchmark-section">
  <h3>Sub-pages</h3>
  <ul>
    <li><a href="/admin/dashboard" data-turbo="false">/admin/dashboard</a> — operational dashboard (article counts + 7-day Activity chart + top feeds / tags)</li>
    <li><a href="/admin/analytics">/admin/analytics</a> — usage analytics (new users + pageviews per day + per-section breakdown, 14-day window default)</li>
    <li><a href="/admin/users">/admin/users</a> — user list with passkey + recovery-code counts</li>
    <li><a href="/admin/cache">/admin/cache</a> — per-feed cache age + manual refresh</li>
    <li><a href="/admin/health">/admin/health</a> — feed-fetch observation history</li>
    <li><a href="/admin/traces">/admin/traces</a> — recent OpenTelemetry spans (in-memory ring buffer)</li>
    <li><a href="/admin/dev-stats">/admin/dev-stats</a> — Claude Code token usage, cost, and shipped work (commits / lines / PRs)</li>
    <li><a href="/admin/llm-quota">/admin/llm-quota</a> — per-user + global LLM rate limit dashboard</li>
    <li><a href="/admin/backgrounds">/admin/backgrounds</a> — page-background image pool (refreshes from Picsum)</li>
    <li><a href="/digests">/digests</a> — stored digests + manual "Generate now" button (same code path as <code>make digest</code>)</li>
    <li><a href="/admin/sidekiq">/admin/sidekiq</a> — background-job Web UI</li>
    <li><a href="/health">/health</a> — JSON liveness + dependency probes (no auth, for uptime monitors)</li>
    <li><a href="/metrics">/metrics</a> — Prometheus exposition format (counters, gauges, histograms)</li>
  </ul>
</section>
