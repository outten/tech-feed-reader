<%# STUFF #83 — test coverage report, populated by SimpleCov on `make test`. %>

<div class="page-header">
  <div>
    <p class="subtitle"><a href="/admin">&larr; Admin</a></p>
    <h2>Test Coverage</h2>
    <% if @last_run != nil || @generated_at %>
      <p class="subtitle">
        Last run: <%= h(@generated_at.strftime('%Y-%m-%d %H:%M UTC')) %>
        &middot; Generated by <code>make test</code>
      </p>
    <% end %>
  </div>
  <% if @report_exists %>
    <div>
      <a href="/admin/coverage/report" target="_blank" rel="noopener" class="btn btn-secondary">
        Open full report ↗
      </a>
    </div>
  <% end %>
</div>

<% if @line_pct.nil? %>
  <div class="admin-coverage-missing">
    <p>No coverage data found.</p>
    <p>Run <code>make test</code> to generate it — SimpleCov writes results to <code>coverage/</code>.</p>
  </div>

<% else %>
  <%# ── Overall scores ── %>
  <section class="benchmark-section">
    <div class="stat-cards stat-cards-pairs">
      <div class="summary-card">
        <span class="summary-num <%= @line_pct >= 90 ? 'green' : @line_pct >= 75 ? 'yellow' : 'red' %>">
          <%= @line_pct %>%
        </span>
        <span class="summary-label">Line coverage</span>
        <% if @covered_lines && @total_lines %>
          <span class="summary-sub muted"><%= @covered_lines %> / <%= @total_lines %> lines</span>
        <% end %>
      </div>
      <% if @branch_pct %>
        <div class="summary-card">
          <span class="summary-num <%= @branch_pct >= 80 ? 'green' : @branch_pct >= 60 ? 'yellow' : 'red' %>">
            <%= @branch_pct %>%
          </span>
          <span class="summary-label">Branch coverage</span>
        </div>
      <% end %>
    </div>

    <div class="admin-coverage-bar-wrap">
      <div class="admin-coverage-bar" style="width:<%= @line_pct %>%"></div>
    </div>
  </section>

  <%# ── Per-file breakdown ── %>
  <% if @files.any? %>
    <section class="benchmark-section">
      <h3>Files — sorted by coverage (lowest first)</h3>
      <table class="data-table">
        <thead>
          <tr>
            <th>File</th>
            <th style="text-align:right">Covered</th>
            <th style="text-align:right">Total</th>
            <th style="text-align:right">Coverage</th>
          </tr>
        </thead>
        <tbody>
          <% @files.each do |f| %>
            <% color = f[:pct] >= 90 ? 'green' : f[:pct] >= 75 ? 'yellow' : 'red' %>
            <tr>
              <td><code class="admin-coverage-file"><%= h(f[:path]) %></code></td>
              <td style="text-align:right"><%= f[:covered] %></td>
              <td style="text-align:right"><%= f[:total] %></td>
              <td style="text-align:right">
                <span class="admin-coverage-pct <%= color %>"><%= f[:pct] %>%</span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% else %>
    <p class="subtitle">
      Per-file breakdown unavailable.
      <% if @report_exists %>
        <a href="/admin/coverage/report" target="_blank">Open the full report</a> for details.
      <% end %>
    </p>
  <% end %>
<% end %>
