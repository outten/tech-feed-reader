<h2>
  Articles
  <% if @feed_filter %> &mdash; <%= @feed_filter['title'] || @feed_filter['url'] %><% end %>
  <% if @tag_filter %> &mdash; <span class="badge tag-chip"><%= @tag_filter['name'] %></span><% end %>
</h2>
<p class="subtitle">
  <% if @feed_filter || @tag_filter %>
    Filtered. <a href="/articles">Clear filter</a>.
  <% else %>
    Filter:
    <% %i[all unread bookmarked archived].each do |state| %>
      <a href="?state=<%= state %>"
         <%= 'class="active"' if @state_filter == state %>><%= state %></a>
    <% end %>
  <% end %>
</p>

<% if @articles.empty? %>
  <section class="benchmark-section">
    <p class="data-source">
      No articles yet. Add a feed via <a href="/feeds">/feeds</a> and
      hit the per-row "Refresh" button (or <code>POST /admin/refresh/all</code>)
      to populate.
    </p>
  </section>
<% else %>
  <section class="benchmark-section">
    <ul class="article-list">
      <% @articles.each do |article| %>
        <li class="<%= article['read'] == 1 ? 'read' : 'unread' %>">
          <a href="/article/<%= article['uid'] %>"><%= article['title'] %></a>
          <% if article['bookmarked'] == 1 %><span class="badge bookmarked">★</span><% end %>
          <% if article['archived']   == 1 %><span class="badge archived">archived</span><% end %>
          <% (@tags_by_article[article['id']] || []).each do |tag| %>
            <a class="badge tag-chip" href="/articles?tag=<%= tag['id'] %>"><%= tag['name'] %></a>
          <% end %>
          <span class="meta">
            <% if (feed = feed_for(article)) %>
              <a href="/articles?feed_id=<%= feed['id'] %>"><%= feed['title'] || feed['url'] %></a> ·
            <% end %>
            <%= relative_time(article['published_at']) %>
            <% if article['author'] && !article['author'].to_s.empty? %>
              · <%= article['author'] %>
            <% end %>
          </span>
        </li>
      <% end %>
    </ul>
  </section>

  <nav class="pager">
    <% if @page > 1 %>
      <a href="?page=<%= @page - 1 %><%= "&feed_id=#{@feed_filter['id']}" if @feed_filter %>">&larr; Prev</a>
    <% end %>
    <span>Page <%= @page %></span>
    <% if @articles.length == @per_page %>
      <a href="?page=<%= @page + 1 %><%= "&feed_id=#{@feed_filter['id']}" if @feed_filter %>">Next &rarr;</a>
    <% end %>
  </nav>
<% end %>
