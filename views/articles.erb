<div class="page-header">
  <div>
    <h2>
      <%= @bookmarks_page ? '★ Bookmarks' : 'Articles' %>
      <% if @feed_filter %> &mdash; <%= h(@feed_filter['title'] || @feed_filter['url']) %><% end %>
      <% if @tag_filter %> &mdash; <span class="tag-chip"><%= h(@tag_filter['name']) %></span><% end %>
      <% if @kind_filter == :podcast %> &mdash; <span class="badge podcast-badge">PODCAST</span><% end %>
    </h2>
    <% if @bookmarks_page %>
      <p class="subtitle">
        Every article you've saved with the ☆ button.
        <% if @articles.any? %>
          <strong><%= @articles.length %></strong> on this page<% if @page > 1 %> (page <%= @page %>)<% end %>.
        <% end %>
      </p>
    <% elsif @feed_filter || @tag_filter %>
      <p class="subtitle">Filtered. <a href="/articles">Clear filter</a>.</p>
    <% else %>
      <p class="subtitle state-filter">
        <%# Every chip uses `filter_url(...)` to preserve the rest of the
            current filter state. Filter changes (state / kind / sort)
            reset pagination via `page: nil` because the new filter
            shows different articles — page 2 of "all" doesn't map to
            page 2 of "unread". The Skim toggle does NOT reset page —
            it's a presentation toggle, not a filter. %>
        <% %i[all unread bookmarked archived].each do |state| %>
          <a href="<%= filter_url(state: state == :all ? nil : state, page: nil) %>"
             class="<%= 'active' if @state_filter == state && @sort_filter != :relevance %>"><%= state %></a>
        <% end %>
        &middot;
        <% if @kind_filter == :podcast %>
          <a href="<%= filter_url %>" class="active">podcasts only</a>
          <a href="<%= filter_url(kind: nil, page: nil) %>">show all</a>
        <% else %>
          <a href="<%= filter_url(kind: :podcast, page: nil) %>">podcasts only</a>
        <% end %>
        &middot;
        <%# Skim toggle preserves `page` deliberately — view is a presentation
            toggle so the user stays on whatever page they were reading. %>
        <% if @view_filter == :skim %>
          <a href="<%= filter_url(view: nil) %>" class="active">skim</a>
        <% else %>
          <a href="<%= filter_url(view: :skim) %>">skim</a>
        <% end %>
        &middot;
        <%# Phase 6 — For You ranker. Forces state=unread (re-ranking
            already-read articles is rarely useful), so the chip both
            sets sort=relevance and clears any non-unread state. %>
        <% if @sort_filter == :relevance %>
          <a href="<%= filter_url(sort: nil, state: :unread, page: nil) %>"
             class="active for-you"
             title="Relevance-ranked unread. Click to switch back to chronological.">For You</a>
        <% else %>
          <a href="<%= filter_url(sort: :relevance, state: :unread, page: nil) %>"
             class="for-you"
             title="Personalised relevance order: blended of recency × per-feed weight × overlap with your 👍 + bookmarked corpus, demoted by 👎 + skip + archive. Click to enable.">For You</a>
        <% end %>
        &middot;
        <%# Sports Phase S1 — top-level topic chips (technology / sports).
            Only render when the user has at least one feed in each
            topic so single-topic users don't see a no-op control. %>
        <% topics_in_use = (@feeds_by_id || {}).values.map { |f| f['topic'] }.uniq.compact %>
        <% if (topics_in_use & %w[technology sports]).length >= 2 %>
          <% if @topic_filter.nil? %>
            <a href="<%= filter_url %>" class="active" title="Showing every topic">all topics</a>
          <% else %>
            <a href="<%= filter_url(topic: nil, page: nil) %>" title="Show every topic">all topics</a>
          <% end %>
          <% FeedCatalog::TOPICS.each do |key, label| %>
            <% k = key.to_s %>
            <% if @topic_filter == k %>
              <a href="<%= filter_url(topic: nil, page: nil) %>" class="active" title="Click to show every topic"><%= label.downcase %></a>
            <% else %>
              <a href="<%= filter_url(topic: k, page: nil) %>" title="Show only <%= label.downcase %> articles"><%= label.downcase %></a>
            <% end %>
          <% end %>
        <% end %>
      </p>
    <% end %>

    <%# STUFF.md follow-up — context strip. Shows current-page count
        in the user's chosen filter + "freshest source today" hint.
        Skipped when filtered to a specific feed/tag — the rest of
        the header already carries the context. %>
    <% unless @feed_filter || @tag_filter %>
      <p class="subtitle articles-context">
        <% if @articles.any? %>
          <strong><%= @articles.length %></strong> <%= @articles.length == 1 ? 'article' : 'articles' %>
          on this page<% if @page > 1 %> (page <%= @page %>)<% end %>
          &middot; <%= @articles_total %> in your corpus
          <% if @most_active_24h_feed %>
            &middot; freshest: <strong><a href="/articles?feed_id=<%= @most_active_24h_feed['id'] %>"><%= h(@most_active_24h_feed['title'] || @most_active_24h_feed['url']) %></a></strong>
            (<%= @most_active_24h_feed['c'] %> in last 24h)
          <% end %>
        <% end %>
      </p>
    <% end %>
  </div>
</div>

<% if @articles.empty? %>
  <div class="empty-state">
    <% if @bookmarks_page %>
      No bookmarks yet. Click the <strong>☆ Bookmark</strong> button on any article (or pick "Bookmark" from the bulk-action toolbar on <a href="/articles">/articles</a>) to save it for later.
    <% elsif @feed_filter || @tag_filter %>
      No articles match this filter.
    <% else %>
      No articles yet. Add a feed at <a href="/feeds">/feeds</a> and click
      "Refresh all" to populate.
    <% end %>
  </div>
<% else %>
  <%# Sticky bulk-action toolbar; appears once a row checkbox is
      ticked. Wired by public/bulk-actions.js. %>
  <div id="bulk-toolbar" class="bulk-toolbar" hidden role="toolbar" aria-label="Bulk actions">
    <span class="bulk-toolbar-count"><span data-bulk-count>0</span> selected</span>
    <button type="button" class="bulk-toolbar-btn" data-bulk-action="read"     title="Mark every selected article as read">Mark read</button>
    <button type="button" class="bulk-toolbar-btn" data-bulk-action="unread"   title="Mark every selected article as unread">Mark unread</button>
    <button type="button" class="bulk-toolbar-btn" data-bulk-action="bookmark" title="Save every selected article (★)">Bookmark</button>
    <button type="button" class="bulk-toolbar-btn" data-bulk-action="archive"  title="Archive every selected article (hides from default views)">Archive</button>
    <button type="button" class="bulk-toolbar-btn bulk-toolbar-clear"          title="Deselect all">Clear</button>
  </div>

  <%# STUFF.md follow-up — precompute source-cluster runs so we can
      emit a "From <feed>" ribbon above any run of 3+ consecutive
      articles from the same feed. Skip when the page is already
      filtered to a specific feed (the cluster IS the page). %>
  <%
    cluster_starts = {}  # index → { feed: row, length: n }
    unless @feed_filter
      i = 0
      while i < @articles.length
        fid = @articles[i]['feed_id']
        j = i
        j += 1 while j < @articles.length && @articles[j]['feed_id'] == fid
        run_len = j - i
        if run_len >= 3 && (feed_row = (@feeds_by_id || {})[fid])
          cluster_starts[i] = { feed: feed_row, length: run_len }
        end
        i = j
      end
    end
    prev_day_group = nil
  %>
  <ul class="news-list <%= 'skim' if @view_filter == :skim %>">
    <% @articles.each_with_index do |article, idx| %>
      <%
        is_podcast = article['audio_url'] && !article['audio_url'].to_s.empty?
        kind_icon  = is_podcast ? '🎧' : '📄'
        kind_label = is_podcast ? 'Podcast episode' : 'Article'
        feed_row   = (@feeds_by_id || {})[article['feed_id']]
        # STUFF.md follow-up — thumbnail fallback chain. Per-article
        # image > YouTube hqdefault (for video feeds) > feed cover art.
        # Always trying to render something so the list has visual
        # rhythm instead of mixed thumb / no-thumb rows.
        thumb_url = article['image_url'].to_s.empty? ? nil : article['image_url']
        thumb_url ||= youtube_thumbnail_url(article)
        thumb_url ||= feed_row && feed_row['image_url']

        # STUFF.md follow-up — day-group dividers. Only render in
        # chronological mode; relevance sort already imposes its own
        # ordering so a day-grouping would be misleading.
        day_group = (@sort_filter == :relevance ? nil : day_group_label_for(article['published_at']))
      %>

      <% if day_group && day_group != prev_day_group %>
        <%# Day-group divider — rendered as a non-list <li role="separator">
            so screen readers don't try to read it as an article. %>
        <li class="news-day-divider" role="separator" aria-label="<%= h(day_group) %>">
          <span class="news-day-label"><%= h(day_group) %></span>
        </li>
        <% prev_day_group = day_group %>
      <% end %>

      <% if (cluster = cluster_starts[idx]) %>
        <%# Source-cluster ribbon — appears above the first row of a
            run of 3+ articles from the same feed. Filter to the feed
            with one click. %>
        <li class="news-source-ribbon" role="separator"
            aria-label="<%= cluster[:length] %> consecutive articles from <%= h(cluster[:feed]['title'] || cluster[:feed]['url']) %>">
          <a href="/articles?feed_id=<%= cluster[:feed]['id'] %>" title="Filter to articles from this feed">
            <span class="news-source-ribbon-label">From</span>
            <strong><%= h(cluster[:feed]['title'] || cluster[:feed]['url']) %></strong>
            <span class="muted"> · <%= cluster[:length] %> in a row</span>
          </a>
        </li>
      <% end %>

      <li class="news-item <%= article['read'] == 1 ? 'read' : '' %> <%= is_podcast ? 'news-item-podcast' : 'news-item-article' %> <%= 'has-thumb' if thumb_url && !thumb_url.to_s.empty? %>">
        <input type="checkbox" class="news-item-check" data-uid="<%= h(article['uid']) %>" aria-label="Select article" title="Select for bulk action">
        <%# STUFF.md follow-up — thumbnail moved to the LEFT of the
            title row and grown to ~80px. Always renders when we can
            construct a URL (per-article > YouTube > feed image). %>
        <% if thumb_url && !thumb_url.to_s.empty? %>
          <a class="news-item-thumb-link" href="/article/<%= article['uid'] %>" title="Open article" aria-hidden="true" tabindex="-1">
            <img class="news-item-thumb" src="<%= h(thumb_url) %>" alt="" loading="lazy">
          </a>
        <% end %>
        <%# STUFF.md #19 — internal link, same-tab navigation. %>
        <a class="news-row-main" href="/article/<%= article['uid'] %>" title="Open article">
          <span class="news-kind-icon" title="<%= kind_label %>" aria-label="<%= kind_label %>"><%= kind_icon %></span>
          <span class="news-headline"><%= h(article['title']) %></span>
        </a>
        <% if @view_filter == :skim %>
          <%
            summary_row = @summaries_by_article_id[article['id']]
            summary_text = skim_summary_for(article, summary_row)
          %>
          <% unless summary_text.empty? %>
            <p class="news-summary-skim"><%= h(summary_text) %></p>
          <% end %>
        <% end %>
        <% feedback_value = article['feedback'].to_i %>
        <% has_persistent_badges = article['bookmarked'] == 1 || article['archived'] == 1 || feedback_value != 0 || (@tags_by_article[article['id']] || []).any? %>
        <div class="news-row-badges <%= 'is-empty' unless has_persistent_badges %>">
          <% if article['bookmarked'] == 1 %><span class="badge bookmarked" title="Bookmarked">★</span><% end %>
          <% if article['archived']   == 1 %><span class="badge archived"   title="Archived">archived</span><% end %>
          <% (@tags_by_article[article['id']] || []).each do |tag| %>
            <a class="tag-chip" href="/articles?tag=<%= tag['id'] %>" title="Filter to articles tagged &lsquo;<%= h(tag['name']) %>&rsquo;"><%= h(tag['name']) %></a>
          <% end %>
          <%# Phase 3 — small inline 👍/👎 affordances. Permanent when
              the user has already given feedback (so the active state
              stays visible), revealed on row hover otherwise. %>
          <span class="news-row-feedback <%= 'feedback-set' if feedback_value != 0 %>">
            <form method="post" action="/article/<%= article['uid'] %>/feedback">
              <input type="hidden" name="value" value="<%= feedback_value == 1 ? '0' : '1' %>">
              <input type="hidden" name="return_to" value="<%= h(request.fullpath) %>">
              <button type="submit" class="feedback-row-btn <%= 'is-on' if feedback_value == 1 %>"
                      title="<%= feedback_value == 1 ? 'Clear the thumbs-up on this article' : 'Thumbs up — boost articles like this one in the For-You sort' %>"
                      aria-label="Thumbs up">👍</button>
            </form>
            <form method="post" action="/article/<%= article['uid'] %>/feedback">
              <input type="hidden" name="value" value="<%= feedback_value == -1 ? '0' : '-1' %>">
              <input type="hidden" name="return_to" value="<%= h(request.fullpath) %>">
              <button type="submit" class="feedback-row-btn <%= 'is-on' if feedback_value == -1 %>"
                      title="<%= feedback_value == -1 ? 'Clear the thumbs-down on this article' : 'Thumbs down — demote articles like this one in the For-You sort' %>"
                      aria-label="Thumbs down">👎</button>
            </form>
          </span>
        </div>
        <div class="news-meta">
          <% if (feed = feed_for(article)) %>
            <a class="news-source" href="/articles?feed_id=<%= feed['id'] %>" title="Show only articles from <%= h(feed['title'] || feed['url']) %>"><%= h(feed['title'] || feed['url']) %></a>
          <% end %>
          <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
          <% if (mins = reading_time_minutes(article)) %>
            <span class="news-reading-time" title="Estimated reading time at ~200 wpm">📖 <%= mins %> min</span>
          <% end %>
          <% if article['author'] && !article['author'].to_s.empty? %>
            <span><%= h(article['author']) %></span>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>

  <nav class="pager">
    <% if @page > 1 %>
      <a href="<%= filter_url(page: (@page - 1 == 1 ? nil : @page - 1)) %>">&larr; Prev</a>
    <% end %>
    <span>Page <%= @page %></span>
    <% if @articles.length == @per_page %>
      <a href="<%= filter_url(page: @page + 1) %>">Next &rarr;</a>
    <% end %>
  </nav>
<% end %>

<script src="/bulk-actions.js?v=<%= asset_mtime('public/bulk-actions.js') %>"></script>
