<%# STUFF #65 — Comics index. Mirrors /podcasts + /youtube in shape:
    a "Recent panels" list of the latest individual strips, plus a
    "Subscribed series" tile grid keyed by feed. Empty state points at
    /feeds catalog browse so users can subscribe to xkcd / SMBC / etc. %>
<div class="page-header">
  <div>
    <h2>Comics</h2>
    <p class="subtitle">
      <% if @series.empty? %>
        No webcomics subscribed yet.
      <% else %>
        <%= @series.length %> series &middot;
        latest panel <%= relative_time(@series.first['latest_at']) %> &middot;
        <a href="/articles?topic=humor" title="Show every panel in a single chronological list">Linear list &rarr;</a>
      <% end %>
    </p>
  </div>
</div>

<% if @series.empty? %>
  <div class="empty-state">
    <p>
      Subscribe to a webcomic from the catalog at <a href="/feeds">/feeds</a> &rarr;
      "Webcomics &amp; humor". xkcd, SMBC, The Oatmeal, and friends. Once you click
      "+ Add" and the next refresh runs, panels show up here.
    </p>
  </div>
<% else %>
  <section class="benchmark-section">
    <h3>Recent panels</h3>
    <% if @recent_comics.empty? %>
      <p class="muted">No panels ingested yet — feeds refresh hourly, so new strips will appear within the next hour.</p>
    <% else %>
      <ul class="podcast-episodes">
        <% @recent_comics.each do |c| %>
          <%
            feed_row = (@feeds_by_id || {})[c['feed_id']]
            # Per-article image_url is where webcomic parsers store the
            # panel. If absent (rare), fall back to the feed's cover so
            # the row still renders with a thumbnail.
            panel = c['image_url'].to_s.empty? ?
                     (feed_row && feed_row['image_url']) :
                     c['image_url']
            # STUFF #66 — surface the source series name on the row.
            # ArticlesStore.recent doesn't JOIN feeds, so the row
            # itself only carries feed_id; look up the title from the
            # @feeds_by_id index loaded in the route.
            series_name = feed_row ? (feed_row['title'] || feed_row['url']) : nil
          %>
          <li class="podcast-card <%= c['read'] == 1 ? 'read' : '' %> <%= 'has-image' if panel && !panel.to_s.empty? %>">
            <% if panel && !panel.to_s.empty? %>
              <a class="podcast-card-image" href="/article/<%= c['uid'] %>" title="Open this panel">
                <img src="<%= h(panel) %>" alt="" loading="lazy">
              </a>
            <% end %>
            <div class="podcast-card-body">
              <h4 class="podcast-card-title">
                <a href="/article/<%= c['uid'] %>"><%= h(c['title']) %></a>
              </h4>
              <p class="podcast-card-meta">
                <% if series_name %>
                  <a href="/comics/<%= c['feed_id'] %>"><%= h(series_name) %></a>
                  &middot;
                <% end %>
                <%= relative_time(c['published_at']) %>
              </p>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>

  <section class="benchmark-section">
    <h3>Subscribed series</h3>
    <div class="podcast-shows">
      <% @series.each do |s| %>
        <%
          # Prefer the latest panel as cover art so the page looks alive
          # (every feed shares its own logo otherwise); fall back to the
          # feed's image_url if no panel image was captured.
          cover = s['latest_image'].to_s.empty? ? s['image_url'] : s['latest_image']
          # STUFF #66 — tile goes to the series archive (/comics/:id)
          # so users can pick which panel to read; was the latest
          # article uid before, which felt like a dead-end.
          target = "/comics/#{s['id']}"
        %>
        <a class="podcast-show-card" href="<%= h(target) %>"
           title="See all panels from <%= h(s['title'] || s['url']) %>">
          <% if cover && !cover.to_s.empty? %>
            <img class="podcast-show-cover" src="<%= h(cover) %>" alt="" loading="lazy">
          <% end %>
          <span class="podcast-show-title"><%= h(s['title'] || s['url']) %></span>
          <span class="podcast-show-meta">
            <%= s['panel_count'] %> panel<%= 's' unless s['panel_count'] == 1 %>
            <% if s['latest_at'] %>
              &middot; latest <%= relative_time(s['latest_at']) %>
            <% end %>
          </span>
        </a>
      <% end %>
    </div>
  </section>
<% end %>
