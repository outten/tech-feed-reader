<div class="page-header">
  <div>
    <h2>Dashboard</h2>
    <p class="subtitle">
      Recent unread articles, top counts, feed activity over time.
    </p>
  </div>
</div>

<% if @degraded %>
  <div class="degradation-banner">
    <span class="banner-icon">⚠</span>
    <span><strong>Feeds are systematically failing.</strong> Check connectivity, then look at <a class="banner-link" href="/admin/health">/admin/health</a>.</span>
  </div>
<% end %>

<div class="stat-cards">
  <div class="summary-card">
    <span class="summary-label">Articles</span>
    <span class="summary-value"><%= @article_count %></span>
    <span class="summary-sub">across <%= @feed_count %> feed<%= 's' unless @feed_count == 1 %></span>
  </div>
  <div class="summary-card">
    <span class="summary-label">Unread</span>
    <span class="summary-value"><%= @unread_count %></span>
    <span class="summary-sub"><a href="/articles?state=unread">view all &rarr;</a></span>
  </div>
  <div class="summary-card">
    <span class="summary-label">Bookmarked</span>
    <span class="summary-value"><%= @bookmark_count %></span>
    <span class="summary-sub"><a href="/articles?state=bookmarked">view all &rarr;</a></span>
  </div>
</div>

<%# STUFF #85 — Stock ticker bar (dashboard-only) %>
<%= erb :_stock_ticker %>

<% if @article_count.positive? %>
  <section class="benchmark-section">
    <h3>Activity (last <%= @activity_window %> day<%= 's' unless @activity_window == 1 %>)</h3>
    <div class="chart-box"><canvas id="dailyChart" height="80"></canvas></div>
  </section>

  <div class="dashboard-grid">
    <section class="benchmark-section">
      <h3>Most active feeds</h3>
      <% if @top_feeds.any? && @top_feeds.first['c'].to_i.positive? %>
        <table class="data-table">
          <tbody>
            <% @top_feeds.each do |feed| %>
              <% next if feed['c'].to_i.zero? %>
              <tr>
                <td><a href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a></td>
                <td class="num"><%= feed['c'] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No articles yet.</p>
      <% end %>
    </section>

    <section class="benchmark-section">
      <h3>Top tags this week</h3>
      <% if @top_tags_week.any? %>
        <p class="tag-cloud">
          <% @top_tags_week.each do |tag| %>
            <a class="tag-chip" href="/articles?tag=<%= tag['id'] %>"><%= h(tag['name']) %> <span class="muted">(<%= tag['count'] %>)</span></a>
          <% end %>
        </p>
      <% else %>
        <p class="muted">
          No tagged articles this week.
          <% if TagsStore.count(current_user_id).zero? %>
            Add a rule at <a href="/tags">/tags</a> to start tagging.
          <% end %>
        </p>
      <% end %>
    </section>
  </div>

  <% if @topic_clusters && @topic_clusters.any? %>
    <section class="benchmark-section">
      <h3>Trending topics (last 14 days)</h3>
      <ul class="topic-list">
        <% @topic_clusters.each do |cluster| %>
          <li class="topic-row">
            <a class="tag-chip" href="/topics/<%= CGI.escape(cluster[:term]) %>">
              <%= h(cluster[:term]) %> <span class="muted">(<%= cluster[:count] %>)</span>
            </a>
            <span class="topic-samples">
              <% cluster[:articles].each_with_index do |article, i| %>
                <% next if i >= 2 %>
                <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a><%= ',' unless i == [cluster[:articles].length, 2].min - 1 %>
              <% end %>
            </span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
<% end %>

<% if @articles.any? %>
  <section class="benchmark-section">
    <h3>Recent unread</h3>
    <ul class="news-list news-list-simple">
      <% @articles.each do |article| %>
        <li class="news-item">
          <% if article['audio_url'] && !article['audio_url'].to_s.empty? %>
            <span class="badge podcast-badge" title="Podcast episode">PODCAST</span>
          <% end %>
          <a class="news-headline" href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
          <% if article['bookmarked'] == 1 %><span class="badge bookmarked">★</span><% end %>
          <div class="news-meta">
            <% if (feed = feed_for(article)) %>
              <a class="news-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
            <% end %>
            <span><%= relative_time(article['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>
    <p class="subtitle" style="margin-top:1rem">
      <a href="/articles">All articles &rarr;</a>
    </p>
  </section>
<% elsif @article_count.zero? %>
  <div class="empty-state">
    No articles yet. <a href="/feeds">Add a feed</a> — the hourly
    refresh cron will pull articles automatically.
  </div>
<% else %>
  <div class="empty-state">
    Inbox zero — no unread articles. Browse <a href="/articles">all</a>
    or your <a href="/articles?state=bookmarked">bookmarks</a>.
  </div>
<% end %>

<% if @article_count.positive? %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
    (function () {
      const data = <%= @daily_counts.to_json %>;

      // Turbo Drive replaces the document on same-app navigation but
      // does not always re-run inline body scripts cleanly — and any
      // existing Chart instance bound to the canvas survives in JS
      // memory. Without this, navigating into /dashboard from another
      // page leaves the canvas blank until a hard refresh forces a
      // full document load. Pattern mirrors public/chat-widget.js.
      function initDashboardChart() {
        const ctx = document.getElementById('dailyChart');
        if (!ctx || !window.Chart) return;
        // Destroy any prior Chart bound to this canvas — guards
        // against duplicate-instance errors on Turbo re-render.
        const prior = Chart.getChart(ctx);
        if (prior) prior.destroy();

        const isDark = document.documentElement.dataset.theme === 'dark';
        const stroke = isDark ? '#0a84ff' : '#0071e3';
        const grid   = isDark ? '#3a3a3c' : '#e5e5ea';
        const muted  = isDark ? '#aeaeb2' : '#8e8e93';

        new Chart(ctx, {
          type: 'line',
          data: {
            labels: data.map(d => d.day.slice(5)),  // MM-DD
            datasets: [{
              label: 'Articles',
              data:  data.map(d => d.count),
              borderColor: stroke,
              backgroundColor: stroke + '22',
              fill: true,
              tension: 0.3,
              pointRadius: 0,
              pointHoverRadius: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, ticks: { color: muted, maxRotation: 0, autoSkip: true, maxTicksLimit: 8 } },
              y: { grid: { color: grid }, ticks: { color: muted, precision: 0 }, beginAtZero: true }
            }
          }
        });
      }

      // Expose the freshly-closured init on window so a single
      // persistent turbo:load listener can always call the latest
      // version (each Turbo nav re-runs this IIFE with new data).
      window.__initDashboardChart = initDashboardChart;

      // First load: run immediately so the chart paints without a
      // flash. Subsequent Turbo navs: the persistent listener below
      // re-runs the (then-current) init on every turbo:load.
      initDashboardChart();

      // Register the turbo:load listener once. Turbo replaces <body>
      // on every navigation, so this IIFE re-runs each time we land
      // on /dashboard — without the guard, listeners would accumulate.
      if (!window.__dashboardChartListener) {
        window.__dashboardChartListener = true;
        document.addEventListener('turbo:load', function () {
          if (typeof window.__initDashboardChart === 'function') {
            window.__initDashboardChart();
          }
        });
      }
    })();
  </script>
<% end %>
