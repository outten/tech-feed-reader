<div class="page-header">
  <div>
    <h2><%= h(@digest['subject']) %></h2>
    <p class="subtitle">
      <a href="/digests" title="Back to all stored digests">&larr; All digests</a>
      &middot; generated <%= relative_time(@digest['generated_at']) %>
      (<code><%= h(@digest['generated_at']) %></code>)
    </p>
  </div>
</div>

<% if params['notice'] == 'llm-summarized' %>
  <div class="notice">Summary generated by <%= h(params['model']) %> and cached on this digest.</div>
<% elsif params['notice'] == 'already-summarized' %>
  <div class="notice">A cached Claude summary already exists for this digest — no new API call was made.</div>
<% elsif params['error'] == 'llm-unavailable' %>
  <div class="error">Claude isn't configured. Set <code>ANTHROPIC_API_KEY</code> in <code>.credentials</code> and restart.</div>
<% elsif params['error'] == 'empty-content' %>
  <div class="error">This digest has no text body to summarise.</div>
<% elsif params['error'] == 'llm-failed' %>
  <div class="error">Claude call failed: <code><%= h(params['msg']) %></code>.</div>
<% end %>

<%# Cached Claude summary block. One-shot — once stored, the
    "Summarize with Claude" button is hidden so the user can't
    accidentally re-spend tokens. %>
<% if @digest['llm_summary'] && !@digest['llm_summary'].to_s.empty? %>
  <section class="benchmark-section digest-llm-summary">
    <h3>
      Claude summary
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; via <%= h(@digest['llm_model'] || '?') %>
        <% if @digest['llm_generated_at'] %>
          &middot; <%= relative_time(@digest['llm_generated_at']) %>
        <% end %>
      </span>
    </h3>
    <p class="excerpt" style="border-left:3px solid #0071e3; padding-left:0.75rem">
      <%= h(@digest['llm_summary']) %>
    </p>
  </section>
<% elsif @claude_available %>
  <div class="portfolio-add" style="margin-bottom:1.5rem">
    <%# data-turbo="false" — the POST takes 5-15s for the Claude call;
        Turbo would intercept and run a silent background fetch. The
        js-digest-summarize hook lets public/digest-summarize-form.js
        swap the button label to "Summarizing… (5-15s)" on submit. %>
    <form method="post" action="/digests/<%= @digest['id'] %>/summarize"
          class="portfolio-form js-digest-summarize" data-turbo="false">
      <button type="submit" class="btn-primary"
              title="Send the digest text to Claude and cache the resulting summary on this row (one-shot — re-visits won't re-spend tokens)">
        Summarize with Claude
      </button>
      <p class="subtitle" style="margin-top:0.5rem">
        One Claude API call. The summary is stored on the digest row, so revisiting this page won't re-spend tokens.
      </p>
    </form>
  </div>
<% end %>

<script src="/digest-summarize-form.js?v=<%= asset_mtime('public/digest-summarize-form.js') %>"></script>

<%# The stored html_body is a self-contained fragment built by
    Digests.build_html. CGI-escaped at composition time, so safe to
    drop in unescaped here — see spec/digests_spec.rb for the XSS
    audit that locks this in. %>
<%= @digest['html_body'] %>
