<div class="page-header">
  <div>
    <h2>Digests</h2>
    <p class="subtitle">
      Snapshots of your unread feed, generated by <code>make digest</code>
      (typically wired to cron). Each row links to the full body.
    </p>
  </div>
</div>

<% if @digests.empty? %>
  <div class="empty-state">
    No digests yet. Run <code>make digest</code> to generate the first one
    &mdash; or wire <code>scripts/generate_digest.rb</code> to your crontab
    so a fresh digest lands every morning.
  </div>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>When</th>
        <th>Window</th>
        <th class="num">Articles</th>
        <th>Subject</th>
      </tr>
    </thead>
    <tbody>
      <% @digests.each do |d| %>
        <tr>
          <td class="muted"><%= relative_time(d['generated_at']) %></td>
          <td class="muted"><%= d['window_hours'] %>h</td>
          <td class="num"><%= d['article_count'] %></td>
          <td><a href="/digests/<%= d['id'] %>"><%= h(d['subject']) %></a></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
