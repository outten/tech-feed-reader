<div class="page-header">
  <div>
    <h2>Digests</h2>
    <p class="subtitle">
      Snapshots of your unread feed, generated by <code>make digest</code>
      (typically wired to cron). Each row links to the full body.
    </p>
  </div>
  <form method="post" action="/digests">
    <button type="submit" class="btn-primary"
            title="Compose + store a digest right now (same as `make digest`)">
      Generate now
    </button>
  </form>
</div>

<% if params['notice'] == 'generated' %>
  <div class="notice">
    Digest generated &mdash; <strong><%= h(params['count']) %></strong> unread article<%= 's' unless params['count'] == '1' %> in the window.
  </div>
<% end %>

<% if @digests.empty? %>
  <div class="empty-state">
    No digests yet. Run <code>make digest</code> to generate the first one
    &mdash; or wire <code>scripts/generate_digest.rb</code> to your crontab
    so a fresh digest lands every morning.
  </div>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>When</th>
        <th>Window</th>
        <th class="num">Articles</th>
        <th>Subject</th>
      </tr>
    </thead>
    <tbody>
      <% @digests.each do |d| %>
        <tr>
          <td class="muted" title="Generated <%= h(d['generated_at']) %>"><%= relative_time(d['generated_at']) %></td>
          <td class="muted" title="Window of unread articles included in the digest"><%= d['window_hours'] %>h</td>
          <td class="num" title="Articles included in this digest"><%= d['article_count'] %></td>
          <td><a href="/digests/<%= d['id'] %>" title="Open the full digest"><%= h(d['subject']) %></a></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
