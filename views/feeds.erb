<h2>Feeds</h2>
<p class="subtitle">Manage subscribed RSS / Atom sources. <%= @feeds.length %> active.</p>

<% if @notice == 'added' %>
  <p class="notice">Feed added.</p>
<% elsif @notice == 'removed' %>
  <p class="notice">Feed removed.</p>
<% elsif @notice == 'refreshed' %>
  <p class="notice">
    Refreshed (status: <%= params['status'] %>;
    <%= params['imported'] %> new article<%= 's' unless params['imported'] == '1' %>).
  </p>
<% elsif @notice == 'refreshed-all' %>
  <p class="notice">
    Refresh-all complete:
    ok=<%= params['ok'] || 0 %>,
    not_modified=<%= params['not_modified'] || 0 %>,
    error=<%= params['error'] || 0 %>,
    <%= params['imported'] || 0 %> new article<%= 's' unless params['imported'] == '1' %>.
  </p>
<% elsif @notice %>
  <p class="notice"><%= @notice %></p>
<% end %>

<% if @error == 'invalid-url' %>
  <p class="error">That doesn't look like a valid http(s) URL.</p>
<% elsif @error == 'duplicate-url' %>
  <p class="error">That feed is already subscribed.</p>
<% elsif @error == 'not-found' %>
  <p class="error">No feed with that id.</p>
<% elsif @error %>
  <p class="error"><%= @error %></p>
<% end %>

<section class="benchmark-section">
  <h3>Add a feed</h3>
  <form method="post" action="/feeds" class="feed-form">
    <label>
      URL
      <input type="url" name="url" required placeholder="https://example.com/feed.xml">
    </label>
    <label>
      Title (optional)
      <input type="text" name="title" placeholder="Auto-filled on first fetch if blank">
    </label>
    <label>
      Poll interval (seconds)
      <input type="number" name="fetch_interval_seconds" min="60" value="<%= FeedsStore::PUBLISHER_INTERVAL %>">
    </label>
    <button type="submit">Add</button>
  </form>
  <p class="data-source">
    Defaults: 900s for high-frequency feeds (HN, Lobsters), 3600s for
    publishers, 14400s for personal blogs. Feeds honour <code>If-Modified-Since</code>
    and <code>ETag</code> when the publisher supports them.
  </p>
</section>

<% if @feeds.any? %>
  <section class="benchmark-section">
    <h3>
      Subscribed
      <form method="post" action="/admin/refresh/all" style="display:inline; margin-left:1em;">
        <button type="submit">Refresh all</button>
      </form>
    </h3>
    <table class="feeds-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>URL</th>
          <th>Interval</th>
          <th>Last fetched</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @feeds.each do |feed| %>
          <tr>
            <td><%= feed['title'] || '<em>(unset)</em>' %></td>
            <td><a href="<%= feed['url'] %>" rel="noopener noreferrer" target="_blank"><%= feed['url'] %></a></td>
            <td><%= feed['fetch_interval_seconds'] %>s</td>
            <td><%= relative_time(feed['last_fetched_at']) %></td>
            <td><%= feed['last_status'] || '—' %></td>
            <td>
              <form method="post" action="/admin/refresh/<%= feed['id'] %>" style="display:inline">
                <button type="submit">Refresh</button>
              </form>
              <form method="post" action="/feeds/<%= feed['id'] %>/delete" style="display:inline" onsubmit="return confirm('Remove this feed and all its articles?');">
                <button type="submit" class="danger">Remove</button>
              </form>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>
