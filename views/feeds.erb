<div class="page-header">
  <div>
    <h2>Feeds</h2>
    <p class="subtitle">
      Manage subscribed RSS / Atom sources. <span id="feed-count"><%= @feeds.length %></span> active.
    </p>
  </div>
  <% if @feeds.any? %>
    <form method="post" action="/admin/refresh/all" class="js-refresh-all">
      <button type="submit" class="refresh-btn" title="Enqueue a fetch for every subscribed feed (background)">Refresh all</button>
    </form>
  <% end %>
</div>

<div id="flash-mount" aria-live="polite"></div>

<% if @notice == 'added' %>
  <div class="notice">Feed added.</div>
<% elsif @notice == 'removed' %>
  <div class="notice">Feed removed.</div>
<% elsif @notice == 'refreshed' %>
  <div class="notice">
    Refreshed (status: <%= h(params['status']) %>;
    <%= h(params['imported']) %> new article<%= 's' unless params['imported'] == '1' %>).
  </div>
<% elsif @notice == 'refreshed-all' %>
  <div class="notice">
    Refresh-all complete:
    ok=<%= h(params['ok'] || '0') %>,
    not_modified=<%= h(params['not_modified'] || '0') %>,
    error=<%= h(params['error'] || '0') %>,
    <%= h(params['imported'] || '0') %> new article<%= 's' unless params['imported'] == '1' %>.
  </div>
<% elsif @notice == 'queued-all' %>
  <div class="notice">
    Queued <strong><%= h(params['count'] || '0') %></strong> feed<%= 's' unless params['count'] == '1' %> for refresh.
    Watch <a href="/admin/sidekiq">/admin/sidekiq</a> for progress.
  </div>
<% elsif @notice == 'queued' %>
  <div class="notice">
    Queued feed for refresh. Watch <a href="/admin/sidekiq">/admin/sidekiq</a> for progress.
  </div>
<% elsif @notice == 'imported' %>
  <div class="notice">
    Imported OPML &middot;
    <%= h(params['added'] || '0') %> added,
    <%= h(params['skipped'] || '0') %> already present
    (<%= h(params['total'] || '0') %> total feeds in the file).
  </div>
<% elsif @notice == 'catalog-added' %>
  <div class="notice">Added <strong><%= h(params['title']) %></strong> from the catalog.</div>
<% elsif @notice == 'already-subscribed' %>
  <div class="notice"><strong><%= h(params['title']) %></strong> is already subscribed.</div>
<% elsif @notice == 'apple-resolved' %>
  <div class="notice">Resolved that Apple Podcasts URL to its underlying RSS feed and added it.</div>
<% elsif @notice == 'mute-added' %>
  <div class="notice">Muted <code><%= h(params['kind']) %>:<%= h(params['value']) %></code> &mdash; matching articles will be hidden from listings (still searchable).</div>
<% elsif @notice == 'mute-duplicate' %>
  <div class="notice">That mute rule already exists.</div>
<% elsif @notice == 'mute-removed' %>
  <div class="notice">Mute rule removed. Matching articles are back in the listings.</div>
<% elsif @notice == 'mute-not-found' %>
  <div class="notice">Mute rule was already gone.</div>
<% elsif @notice %>
  <div class="notice"><%= h(@notice) %></div>
<% end %>

<% if @error == 'invalid-url' %>
  <div class="error">That doesn't look like a valid http(s) URL.</div>
<% elsif @error == 'duplicate-url' %>
  <div class="error">That feed is already subscribed.</div>
<% elsif @error == 'apple-not-found' %>
  <div class="error">Apple Podcasts couldn't find that show (deleted? wrong region?). Try pasting the show's actual RSS URL instead.</div>
<% elsif @error == 'apple-lookup-failed' %>
  <div class="error">Couldn't reach Apple's lookup service. Try again, or paste the show's RSS URL directly.</div>
<% elsif @error == 'not-found' %>
  <div class="error">No feed with that id.</div>
<% elsif @error == 'missing-file' %>
  <div class="error">Pick an OPML file before clicking Import.</div>
<% elsif @error == 'import-failed' %>
  <div class="error">Import failed: <code><%= h(params['msg']) %></code>.</div>
<% elsif @error == 'not-in-catalog' %>
  <div class="error">That URL isn't in the curated catalog. Use the "Add a feed" form for arbitrary URLs.</div>
<% elsif @error %>
  <div class="error"><%= h(@error) %></div>
<% end %>

<div class="portfolio-add">
  <h3>Add a feed</h3>
  <form method="post" action="/feeds" class="portfolio-form js-add-feed">
    <label>
      URL
      <input type="url" name="url" required placeholder="https://example.com/feed.xml">
    </label>
    <label>
      Title (optional)
      <input type="text" name="title" placeholder="Auto-filled on first fetch">
    </label>
    <label>
      Poll interval (seconds)
      <input type="number" name="fetch_interval_seconds" min="60" value="<%= FeedsStore::PUBLISHER_INTERVAL %>">
    </label>
    <button type="submit" class="btn-primary" title="Subscribe to this feed and queue an initial fetch">Add</button>
  </form>
  <p class="subtitle" style="margin-top:0.75rem">
    Suggested intervals: 900s for high-frequency feeds (HN, Lobsters), 3600s
    for publishers, 14400s for personal blogs. <code>If-Modified-Since</code>
    + <code>ETag</code> are honoured when the publisher supports them.
  </p>
</div>

<div class="portfolio-add" style="margin-top:1.25rem">
  <h3>Bulk OPML</h3>
  <form method="post" action="/feeds/import" enctype="multipart/form-data" class="portfolio-form">
    <label class="full-width">
      Import from OPML file
      <input type="file" name="file" accept=".opml,.xml,application/xml,text/x-opml" required title="Pick a .opml or .xml file exported from another reader">
    </label>
    <button type="submit" class="btn-primary" title="Add every feed from the OPML file (already-subscribed URLs are skipped)">Import</button>
  </form>
  <p class="subtitle" style="margin-top:0.75rem">
    Re-import is idempotent — feeds whose URL is already subscribed are
    skipped. <a href="/feeds/export.opml">Download current feed list as OPML &rarr;</a>
  </p>
</div>

<table class="data-table feeds-table" style="margin-top:2rem<%= '; display:none' if @feeds.empty? %>">
  <thead>
    <tr>
      <th>Title</th>
      <th>Interval</th>
      <th>Last fetched</th>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @feeds.each do |feed| %>
      <%= erb :_feed_row, locals: { feed: feed, weight: (@feed_weights || {})[feed['id']] || 1.0 }, layout: false %>
    <% end %>
  </tbody>
</table>

<%# STUFF.md #23 — Ask-AI prompt box. Free-text prompt → Claude picks
    6–8 catalog feeds matching the brief, with a one-line rationale.
    Hidden when ANTHROPIC_API_KEY isn't set. Result is rendered inline
    below the form so the user can subscribe with one click without
    leaving the page. %>
<% if @ai_recommend_available %>
  <section class="benchmark-section feeds-ai-recommend" style="margin-top:2.5rem">
    <h3>✨ Ask AI for feed ideas</h3>
    <p class="subtitle">
      Tell the AI what you're into and it'll pick from the curated catalog.
      It sees your existing subscriptions, so the picks are personalised.
      Examples: <em>"Food and travel writing, Bourdain-style."</em> ·
      <em>"AI safety research blogs."</em> · <em>"Premier League tactics deep dives."</em>
    </p>
    <form method="post" action="/feeds/ai-recommend" class="portfolio-form ai-recommend-form">
      <label class="full-width">
        Your prompt
        <textarea name="prompt" rows="3" required
                  placeholder="What kind of feeds, podcasts, or YouTube channels are you looking for?"><%= h(@ai_prompt) if @ai_prompt %></textarea>
      </label>
      <button type="submit" class="btn-primary" title="Ask Claude to pick matching feeds from the catalog">Recommend feeds</button>
    </form>

    <% if (result = @ai_recommend_result) %>
      <% if result.status == :ok && result.recommendations.any? %>
        <ul class="catalog-list" style="margin-top:1.25rem">
          <% result.recommendations.each do |rec| %>
            <li class="catalog-row" data-catalog-url="<%= h(rec[:url]) %>">
              <div class="catalog-meta">
                <strong><%= h(rec[:title]) %></strong>
                <span class="muted">&middot; <%= h(@categories[rec[:category].to_sym] || rec[:category]) %></span>
                <% unless rec[:blurb].to_s.strip.empty? %>
                  <div class="muted" style="font-size:0.9rem"><%= h(rec[:blurb]) %></div>
                <% end %>
                <div class="ai-rationale">↳ <%= h(rec[:rationale]) %></div>
              </div>
              <form method="post" action="/feeds/catalog/add" class="js-catalog-add">
                <input type="hidden" name="url" value="<%= h(rec[:url]) %>">
                <button type="submit" class="btn-primary">Subscribe</button>
              </form>
            </li>
          <% end %>
        </ul>
        <p class="subtitle" style="margin-top:0.5rem; font-size:0.85rem">
          Picked by Claude <%= h(result.model) %> in <%= result.latency_ms %>ms.
        </p>
      <% elsif result.status == :ok %>
        <p class="subtitle" style="margin-top:1rem">
          Claude didn't find anything matching that prompt in the curated catalog.
          Try a different brief, or use the manual "Add a feed" form above.
        </p>
      <% elsif result.status == :parse_error %>
        <p class="error" style="margin-top:1rem">
          AI response couldn't be parsed. Try again or rephrase. (<%= h(result.error) %>)
        </p>
      <% elsif result.status == :error %>
        <p class="error" style="margin-top:1rem">
          AI call failed: <%= h(result.error) %>
        </p>
      <% elsif result.status == :no_candidates %>
        <p class="subtitle" style="margin-top:1rem">
          You're already subscribed to every feed in the catalog. There's nothing
          new to recommend — try the manual "Add a feed" form above.
        </p>
      <% end %>
    <% end %>
  </section>
<% end %>

<%# Phase 4 follow-up (2026-05-12) — "Recommended for you" callout
    above the full catalog browse. Scores unsubscribed entries against
    the user's existing subscriptions (category × 2 + topic). Empty on
    cold-start (no catalog overlap) so the section auto-hides. %>
<% if (@recommended || []).any? %>
  <section class="benchmark-section feeds-recommended" style="margin-top:2.5rem">
    <h3>✨ Recommended for you <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= @recommended.length %>)</span></h3>
    <p class="subtitle">
      Based on the <%= @subscribed.length %> feed<%= 's' unless @subscribed.length == 1 %> you already subscribe to.
      Adjacent categories + topics; skip what you don't want and the rest of the
      full catalog is below.
    </p>
    <ul class="catalog-list">
      <% @recommended.each do |entry| %>
        <li class="catalog-row" data-catalog-url="<%= h(entry[:url]) %>">
          <div class="catalog-meta">
            <span class="catalog-title"><%= h(entry[:title]) %></span>
            <span class="catalog-blurb"><%= h(entry[:blurb]) %></span>
            <span class="muted catalog-url">
              <%= h(@categories[entry[:category]]) %>
              &middot; <%= h(entry[:url]) %>
            </span>
          </div>
          <form method="post" action="/feeds/catalog/add" class="js-catalog-add">
            <input type="hidden" name="url" value="<%= h(entry[:url]) %>">
            <button type="submit" class="btn-primary" title="Subscribe to &lsquo;<%= h(entry[:title]) %>&rsquo; and queue an initial fetch">+ Add</button>
          </form>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<section class="benchmark-section" style="margin-top:2.5rem">
  <h3>Discover popular feeds</h3>
  <p class="subtitle">
    Hand-picked catalog of <%= FeedCatalog.all.length %> feeds across tech, sports, podcasts,
    nature, and more. Click <strong>Add</strong> on anything that looks interesting —
    the URL goes straight into the subscriptions list. Already-subscribed entries are
    marked.
  </p>
  <% @categories.each do |key, label| %>
    <% entries = @catalog[key] %>
    <% next if entries.empty? %>
    <h4 class="catalog-category"><%= label %></h4>
    <ul class="catalog-list">
      <% entries.each do |entry| %>
        <% subscribed = @subscribed.include?(entry[:url]) %>
        <li class="catalog-row <%= 'subscribed' if subscribed %>" data-catalog-url="<%= h(entry[:url]) %>">
          <div class="catalog-meta">
            <span class="catalog-title"><%= h(entry[:title]) %></span>
            <span class="catalog-blurb"><%= h(entry[:blurb]) %></span>
            <span class="muted catalog-url"><%= h(entry[:url]) %></span>
          </div>
          <% if subscribed %>
            <span class="badge subscribed-badge" title="This feed is already in your subscriptions">✓ Subscribed</span>
          <% else %>
            <form method="post" action="/feeds/catalog/add" class="js-catalog-add">
              <input type="hidden" name="url" value="<%= h(entry[:url]) %>">
              <button type="submit" class="btn-primary" title="Subscribe to &lsquo;<%= h(entry[:title]) %>&rsquo; and queue an initial fetch">+ Add</button>
            </form>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>

<section class="benchmark-section mutes-section" id="mutes" style="margin-top:2.5rem">
  <h3>Muted <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= @mute_rules.values.flatten.length %> rule<%= 's' unless @mute_rules.values.flatten.length == 1 %>)</span></h3>
  <p class="subtitle">
    Hard-hide rules. Articles matching any rule below disappear from
    <a href="/articles">/articles</a> and the dashboard, but stay in the database
    and remain reachable via <a href="/search">/search</a>.
  </p>

  <form method="post" action="/mutes" class="portfolio-form mutes-add">
    <label>
      Kind
      <select name="kind" required title="Keyword = substring match against title + body. Author = exact match. Feed = match by feed id.">
        <option value="keyword">keyword</option>
        <option value="author">author</option>
        <option value="feed">feed</option>
      </select>
    </label>
    <label>
      Value
      <input type="text" name="value" required placeholder="e.g. crypto, John Smith, or feed_id 42">
    </label>
    <button type="submit" class="btn-primary" title="Add this mute rule and hide matching articles from listings">Add mute</button>
  </form>

  <% MuteRulesStore::KINDS.each do |kind| %>
    <% rows = @mute_rules[kind] || [] %>
    <% next if rows.empty? %>
    <h4 class="catalog-category"><%= kind.capitalize %> <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= rows.length %>)</span></h4>
    <ul class="mute-list">
      <% rows.each do |rule| %>
        <li class="mute-row">
          <% if kind == 'feed' %>
            <% feed = FeedsStore.find(rule['value'].to_i) %>
            <span class="mute-value">
              <% if feed %>
                <%= h(feed['title'] || feed['url']) %>
                <span class="muted">&middot; feed_id <%= rule['value'] %></span>
              <% else %>
                <span class="muted">(deleted feed)</span>
                feed_id <%= rule['value'] %>
              <% end %>
            </span>
          <% else %>
            <span class="mute-value"><%= h(rule['value']) %></span>
          <% end %>
          <span class="muted mute-since" title="Created <%= h(rule['created_at']) %>"><%= relative_time(rule['created_at']) %></span>
          <form method="post" action="/mutes/delete" style="display:inline">
            <input type="hidden" name="kind"  value="<%= h(rule['kind']) %>">
            <input type="hidden" name="value" value="<%= h(rule['value']) %>">
            <button type="submit" class="danger" title="Remove this mute rule and surface matching articles again">Unmute</button>
          </form>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @mute_rules.values.flatten.empty? %>
    <p class="subtitle">No mute rules yet.</p>
  <% end %>
</section>

<script src="/feeds.js?v=<%= asset_mtime('public/feeds.js') %>"></script>
