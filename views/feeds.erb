<div class="page-header">
  <div>
    <h2>Feeds</h2>
    <p class="subtitle">
      Manage subscribed RSS / Atom sources. <span id="feed-count"><%= @feeds.length %></span> active.
    </p>
  </div>
</div>

<%# Jump-nav TOC — grouped by topic, one link per category in the catalog. %>
<nav class="catalog-toc" aria-label="Jump to catalog category">
  <%
    toc_groups = {}
    FeedCatalog::TOPICS.each do |topic_key, topic_label|
      cats = FeedCatalog::CATEGORY_TO_TOPIC
        .select { |_c, t| t == topic_key }
        .keys
        .select { |c| (@catalog[c] || []).any? }
      toc_groups[topic_label] = cats unless cats.empty?
    end
  %>
  <% toc_groups.each do |topic_label, cats| %>
    <div class="catalog-toc-group">
      <span class="catalog-toc-topic"><%= h(topic_label) %></span>
      <% cats.each do |cat| %>
        <a href="#cat-<%= cat %>" class="catalog-toc-link"><%= h(FeedCatalog::CATEGORIES[cat]) %></a>
      <% end %>
    </div>
  <% end %>
</nav>

<div id="flash-mount" aria-live="polite"></div>

<% if @notice == 'added' %>
  <div class="notice">Feed added.</div>
<% elsif @notice == 'removed' %>
  <div class="notice">Feed removed.</div>
<% elsif @notice == 'refreshed' %>
  <div class="notice">
    Refreshed (status: <%= h(params['status']) %>;
    <%= h(params['imported']) %> new article<%= 's' unless params['imported'] == '1' %>).
  </div>
<% elsif @notice == 'refreshed-all' %>
  <div class="notice">
    Refresh-all complete:
    ok=<%= h(params['ok'] || '0') %>,
    not_modified=<%= h(params['not_modified'] || '0') %>,
    error=<%= h(params['error'] || '0') %>,
    <%= h(params['imported'] || '0') %> new article<%= 's' unless params['imported'] == '1' %>.
  </div>
<% elsif @notice == 'queued-all' %>
  <div class="notice">
    Queued <strong><%= h(params['count'] || '0') %></strong> feed<%= 's' unless params['count'] == '1' %> for refresh.
    Watch <a href="/admin/sidekiq">/admin/sidekiq</a> for progress.
  </div>
<% elsif @notice == 'queued' %>
  <div class="notice">
    Queued feed for refresh. Watch <a href="/admin/sidekiq">/admin/sidekiq</a> for progress.
  </div>
<% elsif @notice == 'imported' %>
  <div class="notice">
    Imported OPML &middot;
    <%= h(params['added'] || '0') %> added,
    <%= h(params['skipped'] || '0') %> already present
    (<%= h(params['total'] || '0') %> total feeds in the file).
  </div>
<% elsif @notice == 'catalog-added' %>
  <div class="notice">Added <strong><%= h(params['title']) %></strong> from the catalog.</div>
<% elsif @notice == 'already-subscribed' %>
  <div class="notice"><strong><%= h(params['title']) %></strong> is already subscribed.</div>
<% elsif @notice == 'apple-resolved' %>
  <div class="notice">Resolved that Apple Podcasts URL to its underlying RSS feed and added it.</div>
<% elsif @notice == 'mute-added' %>
  <div class="notice">Muted <code><%= h(params['kind']) %>:<%= h(params['value']) %></code> &mdash; matching articles will be hidden from listings (still searchable).</div>
<% elsif @notice == 'mute-duplicate' %>
  <div class="notice">That mute rule already exists.</div>
<% elsif @notice == 'mute-removed' %>
  <div class="notice">Mute rule removed. Matching articles are back in the listings.</div>
<% elsif @notice == 'mute-not-found' %>
  <div class="notice">Mute rule was already gone.</div>
<% elsif @notice %>
  <div class="notice"><%= h(@notice) %></div>
<% end %>

<% if @error == 'invalid-url' %>
  <div class="error">That doesn't look like a valid http(s) URL.</div>
<% elsif @error == 'duplicate-url' %>
  <div class="error">That feed is already subscribed.</div>
<% elsif @error == 'apple-not-found' %>
  <div class="error">Apple Podcasts couldn't find that show (deleted? wrong region?). Try pasting the show's actual RSS URL instead.</div>
<% elsif @error == 'apple-lookup-failed' %>
  <div class="error">Couldn't reach Apple's lookup service. Try again, or paste the show's RSS URL directly.</div>
<% elsif @error == 'not-found' %>
  <div class="error">No feed with that id.</div>
<% elsif @error == 'missing-file' %>
  <div class="error">Pick an OPML file before clicking Import.</div>
<% elsif @error == 'import-failed' %>
  <div class="error">Import failed: <code><%= h(params['msg']) %></code>.</div>
<% elsif @error == 'not-in-catalog' %>
  <div class="error">That URL isn't in the curated catalog. Use the "Add a feed" form for arbitrary URLs.</div>
<% elsif @error %>
  <div class="error"><%= h(@error) %></div>
<% end %>

<%# STUFF.md #23 — Ask-AI prompt box. Hoisted to the top of the page
    so the result is immediately visible after the synchronous POST
    reloads. Result block uses an autoscroll target so the browser
    jumps straight to the response, and a live #ai-thinking indicator
    flips on at submit time (see public/feeds-ai.js) so the user
    knows Claude is working — the round-trip is ~1.5–4s typical. %>
<% if @ai_recommend_available %>
  <section id="ai-feed-recommend" class="benchmark-section feeds-ai-recommend">
    <h3>✨ Ask AI for feed ideas</h3>
    <p class="subtitle">
      Tell the AI what you're into and it'll pick from the curated catalog.
      It sees your existing subscriptions, so the picks are personalised.
      Examples: <em>"Food and travel writing, Bourdain-style."</em> ·
      <em>"AI safety research blogs."</em> · <em>"Premier League tactics deep dives."</em>
    </p>
    <%# data-turbo="false" opts this form out of Turbo's fetch-based form
        submission. Turbo expects successful POSTs to be 3xx redirects; this
        route renders the same /feeds page with a result block inline (200 +
        full HTML). Without the opt-out, Turbo silently keeps the existing
        form on screen and the result block never renders. Native form
        submission + full page navigation is the right model here. %>
    <form method="post" action="/feeds/ai-recommend" data-turbo="false"
          class="portfolio-form ai-recommend-form js-ai-recommend">
      <label class="full-width">
        Your prompt
        <textarea name="prompt" rows="3" required
                  placeholder="What kind of feeds, podcasts, or YouTube channels are you looking for?"><%= h(@ai_prompt) if @ai_prompt %></textarea>
      </label>
      <div class="ai-recommend-controls">
        <button type="submit" class="btn-primary" title="Ask Claude to pick matching feeds from the catalog">Recommend feeds</button>
        <span class="ai-thinking" aria-live="polite">
          <span class="ai-thinking-dot"></span>
          AI is thinking…
        </span>
      </div>
    </form>

    <% if (result = @ai_recommend_result) %>
      <div id="ai-recommend-result" class="ai-recommend-result ai-recommend-result--<%= h(result.status) %>"
           data-status="<%= h(result.status) %>"
           tabindex="-1">
        <% if result.status == :ok && result.recommendations.any? %>
          <h4 class="ai-recommend-result-title">
            <%= result.recommendations.length %>
            <%= result.recommendations.length == 1 ? 'recommendation' : 'recommendations' %>
            for <em>"<%= h(@ai_prompt) %>"</em>
          </h4>
          <%
            # Kind breakdown — surfaces whether Claude returned a mix of
            # rss/podcast/youtube and how many of each survived validation.
            # Useful when results look one-kind-heavy: tells you whether
            # Claude leaned that way, or whether the other kinds got
            # filtered out by validation (likely cause for YouTube: wrong
            # channel IDs).
            kb = result.kind_breakdown || { suggested: {}, validated: {} }
            kind_labels = %w[rss podcast youtube].map do |k|
              s = kb[:suggested][k].to_i
              v = kb[:validated][k].to_i
              next if s.zero?
              "#{k} #{v}/#{s}"
            end.compact
          %>
          <% if result.suggested_count.to_i > result.validated_count.to_i || kind_labels.any? %>
            <p class="subtitle" style="margin-top:-0.25rem">
              <% if result.suggested_count.to_i > result.validated_count.to_i %>
                Claude suggested <%= result.suggested_count %>;
                <%= result.validated_count %> validated as live feeds
                (<%= result.suggested_count - result.validated_count %> couldn't be reached or didn't parse).
              <% end %>
              <% if kind_labels.any? %>
                <span class="muted">By kind (validated/suggested): <%= kind_labels.join(', ') %>.</span>
              <% end %>
            </p>
          <% end %>
          <ul class="catalog-list">
            <% result.recommendations.each do |rec| %>
              <li class="catalog-row" data-catalog-url="<%= h(rec[:url]) %>">
                <div class="catalog-meta">
                  <strong><%= h(rec[:title]) %></strong>
                  <span class="muted">&middot; <%= h(rec[:kind]) %></span>
                  <% if rec[:entry_count].to_i.positive? %>
                    <span class="muted">&middot; <%= rec[:entry_count] %> recent entries</span>
                  <% end %>
                  <div class="muted catalog-url" style="font-size:0.78rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"><%= h(rec[:url]) %></div>
                  <div class="ai-rationale">↳ <%= h(rec[:rationale]) %></div>
                </div>
                <%# Subscribe via the existing manual-add JSON endpoint
                    (POST /api/feeds) so we can insert the row in-place
                    instead of full-reloading the AI panel away. Distinct
                    class from .js-catalog-add to avoid being intercepted
                    by the catalog-add handler in public/feeds.js — that
                    one posts to /api/feeds/catalog/add, which rejects
                    URLs that aren't in the curated catalog (and ours
                    aren't, by design). %>
                <form method="post" action="/api/feeds" class="js-ai-subscribe">
                  <input type="hidden" name="url" value="<%= h(rec[:url]) %>">
                  <input type="hidden" name="title" value="<%= h(rec[:title]) %>">
                  <button type="submit" class="btn-primary">Subscribe</button>
                </form>
              </li>
            <% end %>
          </ul>
        <% elsif result.status == :ok || result.status == :no_validated %>
          <h4 class="ai-recommend-result-title">No verified feeds found</h4>
          <p>
            <% if result.suggested_count.to_i.zero? %>
              Claude didn't have any known free feeds matching
              <em>"<%= h(@ai_prompt) %>"</em>.
            <% else %>
              Claude suggested <%= result.suggested_count %> URLs for
              <em>"<%= h(@ai_prompt) %>"</em>, but none validated as live
              feeds (404 / timeout / not RSS).
            <% end %>
          </p>
          <p class="subtitle">
            Try a more specific prompt, name a publication directly, or
            paste a known feed URL into the manual <strong>Add a feed</strong>
            form below.
          </p>
        <% elsif result.status == :parse_error %>
          <h4 class="ai-recommend-result-title">⚠️ Response couldn't be parsed</h4>
          <p>Try again or rephrase the prompt.</p>
          <p class="subtitle"><code><%= h(result.error) %></code></p>
        <% elsif result.status == :error %>
          <h4 class="ai-recommend-result-title">⚠️ AI call failed</h4>
          <p class="subtitle"><code><%= h(result.error) %></code></p>
        <% end %>

        <% if (result.status == :ok || result.status == :no_validated) && (result.input_tokens || result.output_tokens) %>
          <%
            # Sonnet 4.6 pricing (Anthropic Jan 2025 list): $3 / Mtok input,
            # $15 / Mtok output. Update the constants here when pricing
            # changes — they're inlined rather than configured because
            # mis-estimating cost-per-call by a factor of 2 still tells the
            # user "this is cheap" or "this is expensive" correctly.
            input_per_mtok  = 3.00
            output_per_mtok = 15.00
            in_tokens  = result.input_tokens.to_i
            out_tokens = result.output_tokens.to_i
            cost_usd = (in_tokens * input_per_mtok + out_tokens * output_per_mtok) / 1_000_000.0
          %>
          <p class="ai-recommend-meta">
            <%= h(result.model) %> &middot;
            <%= result.latency_ms %>ms (LLM + validation) &middot;
            <%= in_tokens %> in / <%= out_tokens %> out tokens &middot;
            ≈ $<%= format('%.4f', cost_usd) %>
          </p>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>

<div class="portfolio-add">
  <h3>Add a feed</h3>
  <form method="post" action="/feeds" class="portfolio-form js-add-feed">
    <label>
      URL
      <input type="url" name="url" required placeholder="https://example.com/feed.xml">
    </label>
    <label>
      Title (optional)
      <input type="text" name="title" placeholder="Auto-filled on first fetch">
    </label>
    <label>
      Poll interval (seconds)
      <input type="number" name="fetch_interval_seconds" min="60" value="<%= FeedsStore::PUBLISHER_INTERVAL %>">
    </label>
    <button type="submit" class="btn-primary" title="Subscribe to this feed and queue an initial fetch">Add</button>
  </form>
  <p class="subtitle" style="margin-top:0.75rem">
    Suggested intervals: 900s for high-frequency feeds (HN, Lobsters), 3600s
    for publishers, 14400s for personal blogs. <code>If-Modified-Since</code>
    + <code>ETag</code> are honoured when the publisher supports them.
  </p>
</div>

<div class="portfolio-add" style="margin-top:1.25rem">
  <h3>Bulk OPML</h3>
  <form method="post" action="/feeds/import" enctype="multipart/form-data" class="portfolio-form">
    <label class="full-width">
      Import from OPML file
      <input type="file" name="file" accept=".opml,.xml,application/xml,text/x-opml" required title="Pick a .opml or .xml file exported from another reader">
    </label>
    <button type="submit" class="btn-primary" title="Add every feed from the OPML file (already-subscribed URLs are skipped)">Import</button>
  </form>
  <p class="subtitle" style="margin-top:0.75rem">
    Re-import is idempotent — feeds whose URL is already subscribed are
    skipped. <a href="/feeds/export.opml">Download current feed list as OPML &rarr;</a>
  </p>
</div>

<%# STUFF #27 — filter toolbar for the subscribed feeds table. Pure
    client-side filter (public/feeds-filter.js): the search input filters
    by title/url substring, the chips narrow by topic. Only shows chips
    for topics the user actually has feeds in — no phantom categories. %>
<% if @feeds.any? %>
  <%
    # Build the set of topics the user actually has, in TOPICS order.
    user_topics = @feeds.map { |f| f['topic'].to_s }.uniq
    topic_labels = {
      'technology' => 'Tech', 'sports' => 'Sports', 'nature' => 'Nature',
      'humor' => 'Humor', 'finance' => 'Finance', 'world_news' => 'News',
      'science' => 'Science', 'gaming' => 'Gaming', 'food' => 'Food',
      'health' => 'Health', 'arts' => 'Arts', 'history' => 'History',
      'environment' => 'Climate', 'business' => 'Business',
      'travel' => 'Travel', 'social' => 'Mastodon',
      'npr' => 'NPR', 'pbs' => 'PBS', 'general' => 'General'
    }
    # Keep catalog topic order; fall back to 'general' for unmapped topics
    ordered_user_topics = (FeedCatalog::TOPICS.keys.map(&:to_s) + ['general'])
                            .select { |t| user_topics.include?(t) }
  %>
  <div class="feeds-filter-bar" data-target="feeds-table">
    <input type="search" class="feeds-filter-search" placeholder="Filter your feeds…"
           aria-label="Filter your subscribed feeds by title or URL">
    <div class="feeds-filter-chips" role="tablist" aria-label="Filter by topic">
      <button type="button" class="feeds-filter-chip is-active" data-topic="">All</button>
      <% ordered_user_topics.each do |t| %>
        <button type="button" class="feeds-filter-chip" data-topic="<%= h(t) %>"><%= h(topic_labels[t] || t.capitalize) %></button>
      <% end %>
    </div>
    <span class="feeds-filter-count" aria-live="polite"></span>
  </div>
<% end %>

<table class="data-table feeds-table" style="margin-top:0.5rem<%= '; display:none' if @feeds.empty? %>">
  <thead>
    <tr>
      <th>Title</th>
      <th>Interval</th>
      <th>Last fetched</th>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @feeds.each do |feed| %>
      <%= erb :_feed_row, locals: { feed: feed, weight: (@feed_weights || {})[feed['id']] || 1.0 }, layout: false %>
    <% end %>
  </tbody>
</table>

<%# (Ask-AI section moved to the top of the page — between the
    notices and "Add a feed" — so the response lands in view after
    submit instead of below the feeds table.) %>

<%# Phase 4 follow-up (2026-05-12) — "Recommended for you" callout
    above the full catalog browse. Scores unsubscribed entries against
    the user's existing subscriptions (category × 2 + topic). Empty on
    cold-start (no catalog overlap) so the section auto-hides. %>
<% if (@recommended || []).any? %>
  <section class="benchmark-section feeds-recommended" style="margin-top:2.5rem">
    <h3>✨ Recommended for you <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= @recommended.length %>)</span></h3>
    <p class="subtitle">
      Based on the <%= @subscribed.length %> feed<%= 's' unless @subscribed.length == 1 %> you already subscribe to.
      Adjacent categories + topics; skip what you don't want and the rest of the
      full catalog is below.
    </p>
    <ul class="catalog-list">
      <% @recommended.each do |entry| %>
        <li class="catalog-row" data-catalog-url="<%= h(entry[:url]) %>">
          <div class="catalog-meta">
            <span class="catalog-title"><%= h(entry[:title]) %></span>
            <span class="catalog-blurb"><%= h(entry[:blurb]) %></span>
            <span class="muted catalog-url">
              <%= h(@categories[entry[:category]]) %>
              &middot; <%= h(entry[:url]) %>
            </span>
          </div>
          <form method="post" action="/feeds/catalog/add" class="js-catalog-add">
            <input type="hidden" name="url" value="<%= h(entry[:url]) %>">
            <button type="submit" class="btn-primary" title="Subscribe to &lsquo;<%= h(entry[:title]) %>&rsquo; and queue an initial fetch">+ Add</button>
          </form>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# STUFF #24 — Most Popular feeds across all readers. Renders nothing
    if every type is empty (e.g. brand-new instance with no feeds yet);
    otherwise five strips of top-5 ranked by subscriber count. %>
<%= erb :_popular_feeds, layout: false %>

<section id="discover-catalog" class="benchmark-section" style="margin-top:2.5rem">
  <h3>Discover popular feeds</h3>
  <p class="subtitle">
    Hand-picked catalog of <%= FeedCatalog.all.length %> feeds across tech, sports, podcasts,
    nature, and more. Click <strong>Add</strong> on anything that looks interesting —
    the URL goes straight into the subscriptions list. Already-subscribed entries are
    marked.
  </p>

  <%# STUFF #27 — filter toolbar mirroring the one above the subscribed
      feeds table. Same JS module handles both via the data-target pair.
      Shows all catalog topics so users can discover new categories. %>
  <div class="feeds-filter-bar" data-target="catalog">
    <input type="search" class="feeds-filter-search" placeholder="Filter the catalog…"
           aria-label="Filter catalog feeds by title, blurb, or URL">
    <div class="feeds-filter-chips" role="tablist" aria-label="Filter by topic">
      <button type="button" class="feeds-filter-chip is-active" data-topic="">All</button>
      <% FeedCatalog::TOPICS.each do |key, label| %>
        <button type="button" class="feeds-filter-chip" data-topic="<%= h(key) %>"><%= h(label) %></button>
      <% end %>
    </div>
    <span class="feeds-filter-count" aria-live="polite"></span>
  </div>

  <% @categories.each do |key, label| %>
    <% entries = @catalog[key] %>
    <% next if entries.empty? %>
    <%# data-topic on the category header lets feeds-filter.js hide
        the whole heading when every row beneath it is filtered out. %>
    <h4 id="cat-<%= key %>" class="catalog-category" data-topic="<%= h(FeedCatalog::CATEGORY_TO_TOPIC[key].to_s) %>"><%= label %></h4>
    <ul class="catalog-list">
      <% entries.each do |entry| %>
        <% subscribed = @subscribed.include?(entry[:url]) %>
        <% topic_key  = FeedCatalog.topic_for(entry).to_s %>
        <li class="catalog-row <%= 'subscribed' if subscribed %>"
            data-catalog-url="<%= h(entry[:url]) %>"
            data-topic="<%= h(topic_key) %>"
            data-subscribed="<%= subscribed ? '1' : '0' %>"
            data-search="<%= h([entry[:title], entry[:blurb], entry[:url]].join(' ').downcase) %>">
          <div class="catalog-meta">
            <span class="catalog-title"><%= h(entry[:title]) %></span>
            <span class="catalog-blurb"><%= h(entry[:blurb]) %></span>
            <span class="muted catalog-url"><%= h(entry[:url]) %></span>
          </div>
          <% if subscribed %>
            <span class="badge subscribed-badge" title="This feed is already in your subscriptions">✓ Subscribed</span>
          <% else %>
            <form method="post" action="/feeds/catalog/add" class="js-catalog-add">
              <input type="hidden" name="url" value="<%= h(entry[:url]) %>">
              <button type="submit" class="btn-primary" title="Subscribe to &lsquo;<%= h(entry[:title]) %>&rsquo; and queue an initial fetch">+ Add</button>
            </form>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>

<section class="benchmark-section mutes-section" id="mutes" style="margin-top:2.5rem">
  <h3>Muted <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= @mute_rules.values.flatten.length %> rule<%= 's' unless @mute_rules.values.flatten.length == 1 %>)</span></h3>
  <p class="subtitle">
    Hard-hide rules. Articles matching any rule below disappear from
    <a href="/articles">/articles</a> and the dashboard, but stay in the database
    and remain reachable via <a href="/search">/search</a>.
  </p>

  <form method="post" action="/mutes" class="portfolio-form mutes-add">
    <label>
      Kind
      <select name="kind" required title="Keyword = substring match against title + body. Author = exact match. Feed = match by feed id.">
        <option value="keyword">keyword</option>
        <option value="author">author</option>
        <option value="feed">feed</option>
      </select>
    </label>
    <label>
      Value
      <input type="text" name="value" required placeholder="e.g. crypto, John Smith, or feed_id 42">
    </label>
    <button type="submit" class="btn-primary" title="Add this mute rule and hide matching articles from listings">Add mute</button>
  </form>

  <% MuteRulesStore::KINDS.each do |kind| %>
    <% rows = @mute_rules[kind] || [] %>
    <% next if rows.empty? %>
    <h4 class="catalog-category"><%= kind.capitalize %> <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= rows.length %>)</span></h4>
    <ul class="mute-list">
      <% rows.each do |rule| %>
        <li class="mute-row">
          <% if kind == 'feed' %>
            <% feed = FeedsStore.find(rule['value'].to_i) %>
            <span class="mute-value">
              <% if feed %>
                <%= h(feed['title'] || feed['url']) %>
                <span class="muted">&middot; feed_id <%= rule['value'] %></span>
              <% else %>
                <span class="muted">(deleted feed)</span>
                feed_id <%= rule['value'] %>
              <% end %>
            </span>
          <% else %>
            <span class="mute-value"><%= h(rule['value']) %></span>
          <% end %>
          <span class="muted mute-since" title="Created <%= h(rule['created_at']) %>"><%= relative_time(rule['created_at']) %></span>
          <form method="post" action="/mutes/delete" style="display:inline">
            <input type="hidden" name="kind"  value="<%= h(rule['kind']) %>">
            <input type="hidden" name="value" value="<%= h(rule['value']) %>">
            <button type="submit" class="danger" title="Remove this mute rule and surface matching articles again">Unmute</button>
          </form>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @mute_rules.values.flatten.empty? %>
    <p class="subtitle">No mute rules yet.</p>
  <% end %>
