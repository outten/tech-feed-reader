<%# Public home / landing page. STUFF.md #13 + #14 + #17.
    GET / branches on @returning_user:
      • Anonymous (no read_state activity) → marketing hero + 6
        feature cards + "Information comes to you" narrative.
      • Returning user → What's On Today: today's sports fixtures
        (followed teams), today's articles (For You ranked), today's
        podcasts (audio_url), today's videos (topic=nature).

    The Dashboard moved to /admin/dashboard — it's an ops view, not a
    daily-use surface. / is now where you land when there's stuff to
    read/watch/listen today. %>

<% if @returning_user %>
  <%# STUFF.md #17 + #14 — What's On Today is the home for active
      users. Sections only render when they have rows so a quiet day
      collapses gracefully. %>
  <div class="page-header">
    <div>
      <h2>What's On Today</h2>
      <p class="subtitle">
        <%= Time.now.strftime('%A, %B %-d, %Y') %>
        &middot; You have <strong><%= @stats[:unread] %></strong> unread,
        <strong><%= @stats[:bookmarks] %></strong> bookmarked
        across <strong><%= @stats[:articles] %></strong> articles.
        <% if @latest_triage && @latest_triage['generated_at'] %>
          &middot; Last triage <%= relative_time(@latest_triage['generated_at']) %>.
        <% end %>
      </p>
    </div>
  </div>

  <%# Phase 2 polish (2026-05-12) — "Pick up where you left off" tile.
      Position state for in-progress podcasts + YouTube videos lives in
      localStorage (server can't see it), so this slot starts hidden
      and continue-progress.js scans + fetches + renders client-side.
      Empty visitors → slot stays hidden, no flash. %>
  <section id="continue-progress" class="benchmark-section continue-progress" hidden></section>

  <% if @nothing_today %>
    <div class="empty-state">
      <p><strong>Quiet day.</strong> Nothing new from your followed teams or feeds yet.</p>
      <p class="muted">
        <a href="/articles?sort=relevance&amp;state=unread">Browse your unread queue &rarr;</a>
        &middot;
        <a href="/feeds">Add more feeds &rarr;</a>
      </p>
    </div>
  <% end %>

  <% if (@today_matches || []).any? %>
    <section class="benchmark-section whats-on-section">
      <h3>🏟 Sports today <span class="muted whats-on-count">(<%= @today_matches.length %>)</span></h3>
      <ul class="whats-on-matches">
        <% @today_matches.each do |match| %>
          <% home = (@teams_by_id || {})[match['home_team_id']] %>
          <% away = (@teams_by_id || {})[match['away_team_id']] %>
          <% league = (@leagues_by_id || {})[match['league_id']] %>
          <li class="whats-on-match">
            <span class="whats-on-time">
              <% if match['scheduled_at'] %>
                <%= Time.parse(match['scheduled_at']).getlocal.strftime('%-l:%M %p') rescue match['scheduled_at'] %>
              <% else %>
                TBD
              <% end %>
            </span>
            <span class="whats-on-matchup">
              <% if away %><a href="/sports/team/<%= h(away['slug']) %>"><%= h(away['short_name'] || away['name']) %></a><% else %>—<% end %>
              <span class="muted">@</span>
              <% if home %><a href="/sports/team/<%= h(home['slug']) %>"><%= h(home['short_name'] || home['name']) %></a><% else %>—<% end %>
            </span>
            <% if league %>
              <span class="muted whats-on-league"><%= h(league['name']) %></span>
            <% end %>
            <% if match['status'].to_s == 'live' %>
              <span class="badge live-badge" title="Match is live now">LIVE</span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <p class="subtitle whats-on-foot">
        <a href="/sports/calendar">Full calendar (next 30 days) &rarr;</a>
      </p>
    </section>
  <% end %>

  <% if (@today_reading || []).any? %>
    <section class="benchmark-section whats-on-section">
      <h3>📰 To read today <span class="muted whats-on-count">(<%= @today_reading.length %>)</span></h3>
      <ul class="sports-article-list">
        <% @today_reading.each do |article| %>
          <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
          <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
          <% summary_text = skim_summary_for(article, summary_row) %>
          <li class="sports-article <%= 'read' if article['read'] == 1 %>">
            <h4 class="sports-article-title">
              <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
            </h4>
            <% unless summary_text.empty? %>
              <p class="sports-article-summary"><%= h(summary_text) %></p>
            <% end %>
            <div class="sports-article-meta">
              <% if feed %>
                <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
                <span class="sports-article-meta-sep">&middot;</span>
              <% end %>
              <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="subtitle whats-on-foot">
        <a href="/articles?sort=relevance&amp;state=unread">Full For You queue &rarr;</a>
      </p>
    </section>
  <% end %>

  <% if (@today_listening || []).any? %>
    <section class="benchmark-section whats-on-section">
      <h3>
        🎧 To listen today <span class="muted whats-on-count">(<%= @today_listening.length %>)</span>
        <%# Phase 3 follow-up (2026-05-12) — exposes bus mode in the
            home page rather than only behind the header 🚌 icon. %>
        <% if (@bus_count_today || 0).positive? %>
          <a class="whats-on-bus-chip" href="/bus" title="Open Bus mode — every podcast ≤15 minutes from your subscriptions">
            🚌 <%= @bus_count_today %> short for the bus
          </a>
        <% end %>
      </h3>
      <ul class="sports-article-list">
        <% @today_listening.each do |article| %>
          <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
          <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
          <% summary_text = skim_summary_for(article, summary_row) %>
          <li class="sports-article <%= 'read' if article['read'] == 1 %>">
            <h4 class="sports-article-title">
              <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
              <span class="badge podcast-badge" title="Podcast episode">🎧</span>
            </h4>
            <% unless summary_text.empty? %>
              <p class="sports-article-summary"><%= h(summary_text) %></p>
            <% end %>
            <div class="sports-article-meta">
              <% if feed %>
                <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
                <span class="sports-article-meta-sep">&middot;</span>
              <% end %>
              <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="subtitle whats-on-foot">
        <a href="/podcasts">All podcasts &rarr;</a>
      </p>
    </section>
  <% end %>

  <% if (@today_watching || []).any? %>
    <section class="benchmark-section whats-on-section">
      <h3>📺 To watch today <span class="muted whats-on-count">(<%= @today_watching.length %>)</span></h3>
      <ul class="sports-article-list whats-on-watch">
        <% @today_watching.each do |article| %>
          <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
          <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
          <% summary_text = skim_summary_for(article, summary_row) %>
          <% thumb        = youtube_thumbnail_url(article) %>
          <li class="sports-article whats-on-watch-card <%= 'read' if article['read'] == 1 %>">
            <% if thumb %>
              <a class="whats-on-watch-thumb" href="/article/<%= article['uid'] %>"
                 title="Play <%= h(article['title']) %> in app">
                <img src="<%= h(thumb) %>" alt="" loading="lazy">
                <span class="whats-on-watch-play" aria-hidden="true">▶</span>
              </a>
            <% end %>
            <div class="whats-on-watch-body">
              <h4 class="sports-article-title">
                <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
              </h4>
              <% unless summary_text.empty? %>
                <p class="sports-article-summary"><%= h(summary_text) %></p>
              <% end %>
              <div class="sports-article-meta">
                <% if feed %>
                  <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
                  <span class="sports-article-meta-sep">&middot;</span>
                <% end %>
                <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      <p class="subtitle whats-on-foot">
        <a href="/articles?topic=nature">All nature feeds &rarr;</a>
      </p>
    </section>
  <% end %>

  <script src="/continue-progress.js?v=<%= asset_mtime('public/continue-progress.js') %>"></script>

<% else %>
  <%# Anonymous — full marketing surface: hero + feature cards +
      "Information comes to you" narrative + final CTA. Same content
      as before; the only edit is the Open-dashboard CTAs now point
      at /admin/dashboard (the Dashboard moved). %>
  <section class="home-hero">
    <div class="home-hero-text">
      <h1>Stop swivel-chairing between 50 sites.</h1>
      <p class="home-tagline">
        An RSS reader that <strong>ranks</strong>, <strong>summarizes</strong>,
        and <strong>triages</strong> your feed for you. Self-hosted,
        single-user, no analytics, no algorithmic agenda.
      </p>
      <div class="home-cta">
        <a class="btn-primary" href="/articles?sort=relevance&amp;state=unread">Open the queue &rarr;</a>
        <a class="home-cta-secondary" href="/about">What this is &rarr;</a>
      </div>
      <p class="home-hero-meta">
        Free &middot; Open source &middot; Your data lives on your disk
      </p>
    </div>
    <div class="home-hero-image">
      <img src="/img/home/dashboard.png" alt="Dashboard view: article counts, activity chart, top feeds and tags." loading="lazy">
    </div>
  </section>

  <section class="home-features">
    <article class="home-feature">
      <div class="home-feature-body">
        <h2>🌐 One inbox for everything you read</h2>
        <p>
          Add a curated set of 25+ feeds in one click, or bulk-import OPML.
          Tech, sports, and podcasts share a single ranked queue.
          Stop opening twelve tabs every morning.
        </p>
      </div>
    </article>

    <article class="home-feature home-feature-with-image">
      <div class="home-feature-body">
        <h2>🎯 Ranked for you</h2>
        <p>
          Every article gets a personal score based on what you've bookmarked,
          thumbs-upped, or skipped. The ranker honours your topic preferences —
          sports feedback won't pollute your tech queue, and vice versa.
          Sort: <code>?sort=relevance</code>.
        </p>
      </div>
      <div class="home-feature-image">
        <img src="/img/home/for-you.png" alt="Articles list sorted by personal relevance." loading="lazy">
      </div>
    </article>

    <article class="home-feature home-feature-with-image">
      <div class="home-feature-body">
        <h2>🧠 AI-assisted triage</h2>
        <p>
          One Claude call (Sonnet 4.6) classifies every unread article into
          <strong>Must read</strong>, <strong>Optional</strong>, or <strong>Skip</strong>,
          with a one-sentence rationale that cites <em>your</em> past behaviour:
          "matches your bookmarked Ruby work," "topic you've previously demoted."
          Three runs nightly via cron — one per topic.
        </p>
      </div>
      <div class="home-feature-image">
        <img src="/img/home/triage.png" alt="AI triage page showing Must read / Optional / Skip groups with rationale." loading="lazy">
      </div>
    </article>

    <article class="home-feature home-feature-with-image">
      <div class="home-feature-body">
        <h2>✍️ Summaries you can skim</h2>
        <p>
          Every article gets an extractive summary inline. One click adds a full
          Claude summary cached on the row, so revisits don't re-spend tokens.
          Skim mode hides the noise so you can clear 100 unread in minutes.
        </p>
      </div>
      <div class="home-feature-image">
        <img src="/img/home/digest.png" alt="Daily digest page with cached Claude summary at the top." loading="lazy">
      </div>
    </article>

    <article class="home-feature home-feature-with-image">
      <div class="home-feature-body">
        <h2>🎧 Podcasts that follow you</h2>
        <p>
          A persistent mini-player at the bottom of every page keeps audio
          playing as you navigate. Episodes appear in the same queue as
          articles, with listened-percent + speed-control + skip-15s.
        </p>
      </div>
      <div class="home-feature-image">
        <img src="/img/home/podcasts.png" alt="Podcasts page with subscribed shows and recent episodes." loading="lazy">
      </div>
    </article>

    <article class="home-feature home-feature-with-image">
      <div class="home-feature-body">
        <h2>🏈 Sports — same engine, different domain</h2>
        <p>
          Scores, league standings, calendar export (iCal subscribe), and follows
          for teams + individual tennis players. Articles mentioning your followed
          entities surface on their detail page automatically.
        </p>
      </div>
      <div class="home-feature-image">
        <img src="/img/home/sports.png" alt="Sports landing page with score tiles and league sections." loading="lazy">
      </div>
    </article>
  </section>

  <section class="home-narrative">
    <h2>Information comes to you, not the other way around.</h2>
    <p>
      Most of us spend an hour a day swivel-chairing — Hacker News, then The Verge,
      then Lobsters, then five team-specific blogs, then a podcast app, then back
      to the top because "did I check that one yet?". The platforms call this
      <em>engagement</em>. It's just lost time.
    </p>
    <p>
      Tech Feed Reader inverts that. You declare what you care about. The server
      pulls every feed every ten minutes. Claude triages overnight. The ranker
      learns from your clicks.
    </p>
    <p>
      The algorithm works for <strong>you</strong>, not against you. Nothing is
      optimised for retention. Nothing is monetised. There's no feed of someone
      else's choosing.
    </p>
  </section>

  <section class="home-final-cta">
    <h2>Open it up.</h2>
    <p>
      Start reading, or learn about the philosophy first.
    </p>
    <div class="home-cta">
      <a class="btn-primary" href="/articles?sort=relevance&amp;state=unread">Open the queue &rarr;</a>
      <a class="home-cta-secondary" href="/about">About this project &rarr;</a>
    </div>
  </section>
<% end %>
