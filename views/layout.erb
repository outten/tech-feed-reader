<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tech Feed Reader<%= @page_title ? " — #{h(@page_title)}" : '' %></title>
  <link rel="stylesheet" href="/style.css?v=<%= asset_mtime('public/style.css') %>">
  <script>
    /* Theme bootstrap — runs before <body> renders so there's no FOUC.
       Reads localStorage if set, otherwise honours the OS-level
       prefers-color-scheme. Sets both `data-theme` (so JS like the
       Chart.js init can branch on it) and the `dark` class (which the
       CSS rules key off). */
    (function () {
      try {
        var saved      = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme      = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
        document.documentElement.classList.toggle('dark', theme === 'dark');
      } catch (e) { /* private mode / blocked storage — fall back to default */ }
    })();
  </script>
</head>
<body>
  <header>
    <span class="logo">Tech Feed Reader</span>
    <nav>
      <a href="/dashboard" class="<%= %w[/ /dashboard].include?(request.path_info) ? 'active' : '' %>">Dashboard</a>
      <a href="/topics"    class="<%= request.path_info == '/topics'   ? 'active' : '' %>">Topics</a>
      <a href="/articles"  class="<%= request.path_info == '/articles' ? 'active' : '' %>">Articles</a>
      <a href="/podcasts"  class="<%= request.path_info == '/podcasts' ? 'active' : '' %>">Podcasts</a>
      <a href="/feeds"     class="<%= request.path_info == '/feeds'    ? 'active' : '' %>">Feeds</a>
      <a href="/tags"      class="<%= request.path_info == '/tags'     ? 'active' : '' %>">Tags</a>
      <a href="/search"    class="<%= request.path_info == '/search'   ? 'active' : '' %>">Search</a>
      <a href="/admin"     class="<%= request.path_info.start_with?('/admin') ? 'active' : '' %>">Admin</a>
    </nav>
    <form method="post" action="/admin/refresh/all" class="header-refresh-form js-header-refresh">
      <button type="submit" id="header-refresh" class="header-icon-btn"
              title="Refresh all feeds now" aria-label="Refresh all feeds">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-3-6.7"/>
          <polyline points="21 4 21 12 13 12"/>
        </svg>
      </button>
    </form>
    <div id="header-flash" aria-live="polite"></div>
    <button id="theme-toggle" type="button" title="Toggle light / dark theme" aria-label="Toggle light / dark theme">🌙</button>
  </header>
  <main>
    <%= yield %>
  </main>
  <footer>
    <small>Tech Feed Reader &mdash; Public RSS aggregation for personal use.</small>
  </footer>

  <%# Chat widget — floating button bottom-right opens a panel that
      sends the user's message + the page context to /chat. Hidden by
      chat-widget.js until /chat/health says the API key is configured. %>
  <div id="chat-widget" hidden>
    <button id="chat-widget-toggle" type="button" class="chat-toggle" title="Chat about this page" aria-label="Chat about this page" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
    <div id="chat-widget-panel" class="chat-panel" hidden>
      <header class="chat-panel-header">
        <span class="chat-panel-title">Chat <span class="chat-panel-context muted"></span></span>
        <button type="button" class="chat-panel-clear" title="Clear thread for this page" aria-label="Clear thread">⟲</button>
        <button type="button" class="chat-panel-close" title="Close" aria-label="Close">✕</button>
      </header>
      <div class="chat-panel-messages" role="log" aria-live="polite"></div>
      <form class="chat-panel-form">
        <textarea class="chat-panel-input" rows="2" placeholder="Ask about this page…" aria-label="Chat input"></textarea>
        <button type="submit" class="chat-panel-send">Send</button>
      </form>
    </div>
  </div>

  <script>
    /* Theme toggle — wires the header button to flip the class on
       <html>, persists the choice to localStorage, and updates the
       button glyph (☀️ in dark mode, 🌙 in light). */
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      function paint() {
        var dark = document.documentElement.classList.contains('dark');
        btn.textContent = dark ? '☀️' : '🌙';
        btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
      }
      paint();
      btn.addEventListener('click', function () {
        var dark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', dark);
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) { /* ignore */ }
        paint();
      });
    })();
  </script>

  <%# Page context for the chat widget. Routes can populate
      @chat_context = { title:, excerpt: } to give the assistant
      something to ground its answers in. URL is filled in client-side
      from location.pathname so we don't have to thread it through.
      .to_json alone JSON-escapes quotes but leaves `</` intact, which
      lets a `</script>` substring in the title or excerpt break out
      of this inline <script>. The gsub closes that hole. %>
  <script>
    window.PAGE_CONTEXT = {
      title:   <%= ((@chat_context && @chat_context[:title])   || @page_title || 'Tech Feed Reader').to_json.gsub('</', '<\/') %>,
      excerpt: <%= ((@chat_context && @chat_context[:excerpt]) || '').to_json.gsub('</', '<\/') %>
    };
  </script>
  <script src="/header-refresh.js?v=<%= asset_mtime('public/header-refresh.js') %>"></script>
  <script src="/chat-widget.js?v=<%= asset_mtime('public/chat-widget.js') %>"></script>
</body>
</html>
