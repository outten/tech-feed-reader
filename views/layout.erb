<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feeder<%= @page_title ? " — #{h(@page_title)}" : '' %></title>
  <%# Pre-launch — Open Graph + Twitter card meta so a shared
      Feeder link on Mastodon / Slack / iMessage renders a preview
      card instead of a bare URL. @og_description can be set per-
      page from a route; otherwise we fall back to the marketing
      tagline. og:image is the existing dashboard hero. %>
  <% canonical_url = "#{request.base_url}#{request.path}" %>
  <% og_title       = @page_title ? "Feeder — #{@page_title}" : 'Feeder — RSS that ranks, summarizes, and triages for you' %>
  <% og_description = @og_description || 'An RSS reader that ranks, summarizes, and triages your feed for you. No tracking, no algorithmic agenda. Passkey-only sign-in.' %>
  <meta name="description" content="<%= h(og_description) %>">
  <link rel="canonical" href="<%= h(canonical_url) %>">
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="Feeder">
  <meta property="og:title"       content="<%= h(og_title) %>">
  <meta property="og:description" content="<%= h(og_description) %>">
  <meta property="og:url"         content="<%= h(canonical_url) %>">
  <meta property="og:image"       content="<%= h("#{request.base_url}/img/home/dashboard.png") %>">
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= h(og_title) %>">
  <meta name="twitter:description" content="<%= h(og_description) %>">
  <meta name="twitter:image"       content="<%= h("#{request.base_url}/img/home/dashboard.png") %>">
  <link rel="stylesheet" href="/style.css?v=<%= asset_mtime('public/style.css') %>">
  <%# Hotwire Turbo. Intercepts link clicks + form submits, fetches
      HTML via XHR, swaps <body> in place. Lets the mini-player below
      keep its <audio> alive across page changes (the
      data-turbo-permanent attribute on #global-player tells Turbo
      to leave the element untouched on swap). Without Turbo, every
      navigation = new document = audio stops + browser blocks
      autoplay on the new page. %>
  <%# Turbo 8.0.4, self-hosted from public/turbo.js (was loaded render-blocking
      from unpkg.com — external dependency + ~200ms on every first paint). Update
      by re-downloading dist/turbo.es2017-umd.js for the new version; asset_mtime
      busts the cache and data-turbo-track="reload" forces a full reload on change. %>
  <script src="/turbo.js?v=<%= asset_mtime('public/turbo.js') %>" data-turbo-track="reload"></script>
  <script>
    /* Theme bootstrap — runs before <body> renders so there's no FOUC.
       Reads localStorage if set, otherwise honours the OS-level
       prefers-color-scheme. Sets both `data-theme` (so JS like the
       Chart.js init can branch on it) and the `dark` class (which the
       CSS rules key off). */
    (function () {
      try {
        var saved      = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme      = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
        document.documentElement.classList.toggle('dark', theme === 'dark');
      } catch (e) { /* private mode / blocked storage — fall back to default */ }
    })();
  </script>
</head>
<body>
  <header>
    <%# STUFF.md #14 — title is a link to /, with data-turbo="false"
        so the click does a full document refresh (Turbo would otherwise
        do an SPA-style swap that doesn't always feel like "go home"). %>
    <%# STUFF #50 — brand renamed from "Tech Feed Reader" to "Feeder".
        Animal icon is picked at random per request from a pool of
        things-that-get-fed: birds (bird feeder pun), barnyard animals
        (the user's hint), and a bee for variety. %>
    <% logo_emoji = %w[🐦 🦜 🐤 🦉 🦅 🦆 🦢 🐄 🐷 🐝].sample %>
    <a class="logo" href="/" data-turbo="false" title="Home">
      <span class="logo-icon" aria-hidden="true"><%= logo_emoji %></span>
      <span class="logo-word">Feeder</span>
    </a>
    <%# STUFF.md #39 — signed-in-only navigation. Logged-out visitors only
        see the logo + sign-in / sign-up CTAs + theme toggle. The nav
        below points exclusively at routes that require auth (Articles,
        Podcasts, Sports, Admin, …) — for an anonymous visitor every
        link would just 302 to /sign-in, which the user reported as a
        confusing dead-end. Bus mode is likewise scoped to the
        signed-in surface. STUFF.md #15 — nav consolidated from
        11 flat links to 6 visible + 2 dropdowns + a search icon. %>
    <% if signed_in? %>
      <%
        ai_paths      = %w[/topics /triage /digests]
        manage_paths  = %w[/feeds /tags /sports/manage /radio]
        # STUFF #65 — Browse ▾ consolidates the per-content-type
        # destinations (Podcasts / YouTube / Sports / Comics) under
        # one parent so adding new content types doesn't keep growing
        # the horizontal nav. /sports/manage is excluded so it lights
        # up Manage ▾ instead of Browse ▾.
        browse_paths  = %w[/podcasts /youtube /sports /comics /games /radio /stocks /npr /pbs]
        ai_active     = ai_paths.any?     { |p| request.path_info == p || request.path_info.start_with?(p + '/') }
        manage_active = manage_paths.any? { |p| request.path_info == p }
        browse_active = !manage_active && browse_paths.any? { |p|
          request.path_info == p || request.path_info.start_with?(p + '/')
        }
      %>
      <nav>
        <%# STUFF.md follow-up: Dashboard moved under /admin/dashboard;
            What's On now lives at / (returning users) so the dedicated
            /whats-on link is redundant. Title-click reaches both for
            returning users. /dashboard is one click further into Admin.
            STUFF #65 — content-type links moved under Browse ▾. %>
        <a href="/articles"  class="<%= request.path_info == '/articles' ? 'active' : '' %>">Articles</a>
        <a href="/bookmarks" class="<%= request.path_info == '/bookmarks' ? 'active' : '' %>" title="Articles you've saved">★ Bookmarks</a>

        <div class="nav-dropdown <%= 'active' if browse_active %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">Browse <span class="nav-dropdown-caret" aria-hidden="true">▾</span></button>
          <div class="nav-dropdown-menu" role="menu">
            <a href="/podcasts" class="<%= 'active' if request.path_info == '/podcasts' %>" role="menuitem">Podcasts</a>
            <a href="/youtube"  class="<%= 'active' if request.path_info == '/youtube' || request.path_info.start_with?('/youtube/') %>" role="menuitem">YouTube</a>
            <a href="/sports"   class="<%= 'active' if (request.path_info == '/sports' || request.path_info.start_with?('/sports/')) && request.path_info != '/sports/manage' %>" role="menuitem">Sports</a>
            <a href="/comics"   class="<%= 'active' if request.path_info == '/comics' || request.path_info.start_with?('/comics/') %>" role="menuitem">Comics</a>
            <a href="/games"    class="<%= 'active' if request.path_info.start_with?('/games') %>" role="menuitem">🎮 Games</a>
            <a href="/radio"    class="<%= 'active' if request.path_info.start_with?('/radio') %>" role="menuitem">📻 Radio</a>
            <a href="/stocks"   class="<%= 'active' if request.path_info.start_with?('/stocks') %>" role="menuitem">📈 Stocks</a>
            <a href="/npr"      class="<%= 'active' if request.path_info.start_with?('/npr') %>"   role="menuitem">NPR</a>
            <a href="/pbs"      class="<%= 'active' if request.path_info.start_with?('/pbs') %>"   role="menuitem">PBS</a>
          </div>
        </div>

        <div class="nav-dropdown <%= 'active' if ai_active %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">AI <span class="nav-dropdown-caret" aria-hidden="true">▾</span></button>
          <div class="nav-dropdown-menu" role="menu">
            <a href="/triage"  class="<%= 'active' if request.path_info == '/triage' || request.path_info.start_with?('/triage/') %>" role="menuitem">Triage</a>
            <a href="/topics"  class="<%= 'active' if request.path_info == '/topics' || request.path_info.start_with?('/topics/') %>" role="menuitem">Topics</a>
            <a href="/digests" class="<%= 'active' if request.path_info.start_with?('/digests') %>" role="menuitem">Digests</a>
          </div>
        </div>

        <div class="nav-dropdown <%= 'active' if manage_active %>">
          <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">Manage <span class="nav-dropdown-caret" aria-hidden="true">▾</span></button>
          <div class="nav-dropdown-menu" role="menu">
            <a href="/feeds"          class="<%= 'active' if request.path_info == '/feeds' %>"          role="menuitem">Feeds</a>
            <a href="/tags"           class="<%= 'active' if request.path_info == '/tags'  %>"          role="menuitem">Tags</a>
            <a href="/sports/manage"  class="<%= 'active' if request.path_info == '/sports/manage' %>"  role="menuitem">Sports</a>
            <a href="/radio"          class="<%= 'active' if request.path_info.start_with?('/radio') %>" role="menuitem">📻 Radio</a>
          </div>
        </div>

        <%# STUFF #49 — disable Turbo's hover-prefetch on the Admin link.
            Turbo 8 prefetches links on hover by default; without the
            opt-out, hovering over "Admin" triggers a silent GET /admin
            which 401s + sets WWW-Authenticate, causing the browser to
            pop a Basic Auth prompt even on non-admin pages. %>
        <a href="/admin" data-turbo-prefetch="false"
           class="<%= request.path_info.start_with?('/admin') ? 'active' : '' %>">Admin</a>
      </nav>
      <%# STUFF #50 — Search sits with the icon-utility buttons (Bus,
          Refresh, etc.) rather than inside the section-nav: it's a
          global tool, not a page section. %>
      <a href="/search" class="header-icon-btn <%= 'active' if request.path_info == '/search' %>"
         title="Search (press / from anywhere)" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>
      <a href="/bus" class="header-icon-btn <%= 'active' if request.path_info == '/bus' %>"
         title="Bus mode — recent podcast episodes short enough for the commute"
         aria-label="Bus mode">
        <%# Stylised side-view bus: body, two windows, two wheels. 20×16
            to match the refresh icon's visual weight. %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 18" width="20" height="16"
             fill="none" stroke="currentColor" stroke-width="1.6"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="11" rx="2"/>
          <line x1="2" y1="7" x2="22" y2="7"/>
          <line x1="9" y1="2" x2="9" y2="7"/>
          <line x1="15" y1="2" x2="15" y2="7"/>
          <circle cx="7" cy="14" r="2"/>
          <circle cx="17" cy="14" r="2"/>
        </svg>
      </a>
    <% else %>
      <%# Logged-out: push the auth CTAs out to the right edge so the
          header doesn't feel half-empty. The block below the auth-chip
          branch already renders Sign in / Sign up; this margin-auto
          rule lives on the .logo, so nothing extra needed here — just
          omit the nav + bus + refresh blocks. %>
    <% end %>
    <div id="header-flash" aria-live="polite"></div>
    <%# Phase A1 (consumer auth) — signed-in chip + Sign out button, or
        Sign in / Sign up links for visitors. STUFF #29 follow-up: the
        chip is now a link to /account where the user can edit their
        profile, manage passkeys, regenerate recovery codes, and
        delete their account. %>
    <% if signed_in? %>
      <a href="/account" class="auth-chip" title="Manage your account (signed in as <%= h(current_user['username']) %>)">
        <%= h(current_user['display_name'] || current_user['username']) %>
      </a>
      <form method="post" action="/sign-out" class="auth-signout-form">
        <button type="submit" class="header-icon-btn" title="Sign out" aria-label="Sign out">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18"
               fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </button>
      </form>
    <% elsif request.path_info != '/sign-in' && request.path_info != '/sign-up' %>
      <a href="/sign-in" class="auth-header-link">Sign in</a>
      <a href="/sign-up" class="auth-header-link auth-header-link-primary">Sign up</a>
    <% end %>
    <button id="theme-toggle" type="button" title="Toggle light / dark theme" aria-label="Toggle light / dark theme">🌙</button>
  </header>
  <main>
    <%# Global stock ticker — followed symbols + major indices, signed-in
        only, cache-only. Renders nothing when there are no quotes. %>
    <%= erb :_stock_ticker, layout: false %>
    <%= yield %>
  </main>
  <footer>
    <small>
      Feeder &mdash; Public RSS aggregation for personal use.
      &middot;
      <a href="/about" title="What this is + the philosophy behind it">About</a>
      &middot;
      <a href="/privacy" title="What we collect, how we use it, who else sees it">Privacy</a>
      &middot;
      <a href="/terms" title="Acceptable use + warranty disclaimer">Terms</a>
      &middot;
      <a href="/contact" title="Send a message to the operator (form-based, no email required)">Contact</a>
      &middot;
      <a href="#" data-bg-shuffle title="Pick a new random nature background">shuffle background</a>
      <%# STUFF #42.1 — voluntary tipping. Renders only when
          BMC_HANDLE is set in the runtime env so dev/test builds
          don't show it. Helps cover the ~$32/mo infra + Anthropic
          API spend without ads. Opens in a new tab — outbound
          payment flow shouldn't dump the user out of the app. %>
      <% if ENV['BMC_HANDLE'] && !ENV['BMC_HANDLE'].empty? %>
        &middot;
        <a href="https://www.buymeacoffee.com/<%= ENV['BMC_HANDLE'] %>"
           target="_blank" rel="noopener noreferrer"
           class="support-link"
           title="Support this project — covers the infra + AI API costs">☕ Support</a>
      <% end %>
      &middot;
      <span class="app-version" title="Build: <%= AppVersion::GIT_SHA %>">v<%= AppVersion::SEMVER %></span>
      <span data-bg-attribution class="bg-attribution"></span>
    </small>
  </footer>

  <%# Persistent mini-player — pinned bottom of the viewport, holds
      the only <audio> element in the app. data-turbo-permanent
      tells Turbo to preserve this DOM node across navigations, so
      audio doesn't stop when you click a link. Article pages bind
      a "Play episode" button to window.Player.load(...) instead
      of rendering their own <audio>. Hidden until something is
      loaded; close (✕) returns to hidden + clears state. %>
  <div id="global-player" data-turbo-permanent hidden>
    <audio id="global-audio" preload="metadata"></audio>
    <div class="mini-player">
      <a href="#" class="mini-player-title" id="mini-player-title">—</a>
      <div class="mini-player-controls">
        <button type="button" class="mini-player-btn" id="mini-player-skip-back" aria-label="Skip back 15 seconds" title="Skip back 15s">
          <span class="mini-player-icon">⟲</span><span class="mini-player-icon-label">15</span>
        </button>
        <button type="button" class="mini-player-btn mini-player-play" id="mini-player-play" aria-label="Play / pause" title="Play / pause">▶</button>
        <button type="button" class="mini-player-btn" id="mini-player-skip-fwd" aria-label="Skip forward 30 seconds" title="Skip forward 30s">
          <span class="mini-player-icon">⟳</span><span class="mini-player-icon-label">30</span>
        </button>
        <span class="mini-player-time">
          <span id="mini-player-current">0:00</span><span class="mini-player-time-sep"> / </span><span id="mini-player-duration">—</span>
        </span>
        <input type="range" class="mini-player-scrubber" id="mini-player-scrubber" min="0" max="100" value="0" step="0.1" aria-label="Seek">
        <select class="mini-player-rate" id="mini-player-rate" aria-label="Playback rate">
          <option value="1">1×</option>
          <option value="1.25">1.25×</option>
          <option value="1.5">1.5×</option>
          <option value="1.75">1.75×</option>
          <option value="2">2×</option>
        </select>
        <button type="button" class="mini-player-btn mini-player-close" id="mini-player-close" aria-label="Close player" title="Close">✕</button>
      </div>
    </div>
  </div>

  <%# Chat widget — floating button bottom-right opens a panel that
      sends the user's message + the page context to /chat. Hidden by
      chat-widget.js until /chat/health says the API key is configured.
      data-turbo-permanent so the panel + open/closed state survive
      Turbo navigations. %>
  <div id="chat-widget" data-turbo-permanent hidden>
    <button id="chat-widget-toggle" type="button" class="chat-toggle" title="Chat about this page" aria-label="Chat about this page" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
    <div id="chat-widget-panel" class="chat-panel" hidden>
      <header class="chat-panel-header">
        <span class="chat-panel-title">Chat <span class="chat-panel-context muted"></span></span>
        <button type="button" class="chat-panel-clear" title="Clear thread for this page" aria-label="Clear thread">⟲</button>
        <button type="button" class="chat-panel-close" title="Close" aria-label="Close">✕</button>
      </header>
      <div class="chat-panel-messages" role="log" aria-live="polite"></div>
      <form class="chat-panel-form">
        <textarea class="chat-panel-input" rows="2" placeholder="Ask about this page…" aria-label="Chat input"></textarea>
        <button type="submit" class="chat-panel-send">Send</button>
      </form>
    </div>
  </div>

  <script>
    /* Theme toggle — wires the header button to flip the class on
       <html>, persists the choice to localStorage, and updates the
       button glyph (☀️ in dark mode, 🌙 in light). */
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      function paint() {
        var dark = document.documentElement.classList.contains('dark');
        btn.textContent = dark ? '☀️' : '🌙';
        btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
      }
      paint();
      btn.addEventListener('click', function () {
        var dark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', dark);
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) { /* ignore */ }
        paint();
      });
    })();
  </script>

  <%# Page context for the chat widget. Routes can populate
      @chat_context = { title:, excerpt: } to give the assistant
      something to ground its answers in. URL is filled in client-side
      from location.pathname so we don't have to thread it through.
      .to_json alone JSON-escapes quotes but leaves `</` intact, which
      lets a `</script>` substring in the title or excerpt break out
      of this inline <script>. The gsub closes that hole. %>
  <script>
    window.PAGE_CONTEXT = {
      title:   <%= ((@chat_context && @chat_context[:title])   || @page_title || 'Feeder').to_json.gsub('</', '<\/') %>,
      excerpt: <%= ((@chat_context && @chat_context[:excerpt]) || '').to_json.gsub('</', '<\/') %>
    };
    <%# Picsum IDs for the page-background rotation. /admin/backgrounds
        rewrites the underlying table; if it's empty we fall back to
        BackgroundPool::DEFAULT_IDS, which mirrors the bundled curated
        set. ERB escapes nothing here since the values are integers,
        but JSON-encoding is still the safe channel. %>
    window.PAGE_BACKGROUND_IDS = <%= BackgroundPool.ids.to_json %>;
  </script>
  <script src="/page-background.js?v=<%= asset_mtime('public/page-background.js') %>"></script>
  <script src="/global-player.js?v=<%= asset_mtime('public/global-player.js') %>"></script>
  <script src="/chat-widget.js?v=<%= asset_mtime('public/chat-widget.js') %>"></script>
  <script src="/search-shortcut.js?v=<%= asset_mtime('public/search-shortcut.js') %>"></script>
  <script src="/sports-follow.js?v=<%= asset_mtime('public/sports-follow.js') %>"></script>
  <script src="/stock-follow.js?v=<%= asset_mtime('public/stock-follow.js') %>"></script>
  <script src="/stock-news.js?v=<%= asset_mtime('public/stock-news.js') %>"></script>
  <script src="/image-lightbox.js?v=<%= asset_mtime('public/image-lightbox.js') %>"></script>
  <script src="/sudoku.js?v=<%= asset_mtime('public/sudoku.js') %>"></script>
  <script src="/trivia.js?v=<%= asset_mtime('public/trivia.js') %>"></script>
  <script src="/radio.js?v=<%= asset_mtime('public/radio.js') %>"></script>
  <script src="/nav-dropdown.js?v=<%= asset_mtime('public/nav-dropdown.js') %>"></script>
  <script src="/source-page.js?v=<%= asset_mtime('public/source-page.js') %>"></script>
  <%# 👍/👎 feedback — article list rows AND the article detail page (#99). %>
  <script src="/article-feedback.js?v=<%= asset_mtime('public/article-feedback.js') %>"></script>
  <%# Lazy "Read next" card on the article page (speed-up-article-load). %>
  <script src="/read-next.js?v=<%= asset_mtime('public/read-next.js') %>"></script>
</body>
</html>
