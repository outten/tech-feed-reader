<div class="page-header">
  <div>
    <h2>Search</h2>
    <p class="subtitle">
      Full-text search across article titles + extracted body text.
      FTS5 syntax — quoted phrases, AND/OR/NOT, prefix-with-* — works.
    </p>
  </div>
</div>

<div class="portfolio-add">
  <form action="/search" method="get" class="portfolio-form">
    <label class="full-width">
      Query
      <input type="text" name="q" value="<%= h(@query) %>" placeholder='kubernetes ebpf, "exact phrase", ai NOT crypto' autofocus>
    </label>
    <button type="submit" class="btn-primary" title="Run the FTS5 query and return matching articles">Search</button>
  </form>
</div>

<% if @error %>
  <div class="error">
    Query syntax error: <code><%= h(@error) %></code>. Try removing quotes
    or special characters, or wrapping the whole thing in <code>"…"</code>.
  </div>
<% end %>

<% if !@query.empty? && !@error %>
  <% if @results.empty? %>
    <div class="empty-state">
      No results for <code><%= h(@query) %></code>.
      Try <a href="/search?q=<%= CGI.escape(@query) %>%2A">prefix-match with <code>*</code></a>
      if it's an unusual word.
    </div>
  <% else %>
    <p class="subtitle" style="margin-top:1.25rem">
      Results for <code><%= h(@query) %></code>
      <span class="muted">(page <%= @page %>, showing <%= @results.length %>)</span>
    </p>
    <ul class="news-list">
      <% @results.each do |article| %>
        <li class="news-item <%= article['read'] == 1 ? 'read' : '' %>">
          <a class="news-headline" href="/article/<%= article['uid'] %>" title="Open article"><%= h(article['title']) %></a>
          <% (@tags_by_article[article['id']] || []).each do |tag| %>
            <a class="tag-chip" href="/articles?tag=<%= tag['id'] %>" title="Filter to articles tagged &lsquo;<%= h(tag['name']) %>&rsquo;"><%= h(tag['name']) %></a>
          <% end %>
          <p class="excerpt"><%= article['excerpt'] %></p>
          <div class="news-meta">
            <% if (feed = @feeds_by_id[article['feed_id']]) %>
              <a class="news-source" href="/articles?feed_id=<%= feed['id'] %>" title="Show only articles from <%= h(feed['title'] || feed['url']) %>"><%= h(feed['title'] || feed['url']) %></a>
            <% end %>
            <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>

    <nav class="pager">
      <% if @page > 1 %>
        <a href="?q=<%= CGI.escape(@query) %>&page=<%= @page - 1 %>">&larr; Prev</a>
      <% end %>
      <span>Page <%= @page %></span>
      <% if @results.length == @per_page %>
        <a href="?q=<%= CGI.escape(@query) %>&page=<%= @page + 1 %>">Next &rarr;</a>
      <% end %>
    </nav>
  <% end %>
<% end %>
