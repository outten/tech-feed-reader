<div class="page-header">
  <div>
    <h2><%= h(@league['name']) %> &mdash; Standings</h2>
    <p class="subtitle">
      <a href="/sports">&larr; All sports</a>
      <% if @standings_groups.any? %>
        &middot; <%= @standings_groups.values.flatten.length %> teams across
        <%= @standings_groups.keys.length %> group<%= 's' unless @standings_groups.keys.length == 1 %>
        <% latest = @standings_groups.values.flatten.map { |r| r['last_synced_at'] }.compact.max %>
        <% if latest %>&middot; updated <%= relative_time(latest) %><% end %>
      <% end %>
    </p>
  </div>
</div>

<% if @standings_groups.empty? %>
  <div class="empty-state">
    <p>No standings synced for this league yet. Run <code>make sync-sports</code> to populate.</p>
  </div>
<% else %>
  <% @standings_groups.each do |group_name, rows| %>
    <section class="benchmark-section sports-standings-group" style="margin-top:1.5rem">
      <h3 class="sports-standings-heading"><%= h(group_name) %></h3>
      <table class="data-table sports-standings-table">
        <thead>
          <tr>
            <th class="sports-standings-pos">#</th>
            <th>Team</th>
            <th class="num">W</th>
            <th class="num">L</th>
            <% if rows.any? { |r| r['ties'] && r['ties'].to_i > 0 } %>
              <th class="num">T</th>
            <% end %>
            <th class="num">PCT</th>
            <th class="num">PF</th>
            <th class="num">PA</th>
            <th class="num">DIFF</th>
            <th>Streak</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |row| %>
            <% team = (@teams_by_id || {})[row['team_id']] %>
            <% next unless team %>
            <% followed = @followed_slugs.include?(team['slug']) %>
            <tr class="<%= 'sports-standings-followed' if followed %>">
              <td class="sports-standings-pos"><%= row['position'] || '—' %></td>
              <td>
                <a class="sports-standings-team-link" href="/sports/team/<%= h(team['slug']) %>"
                   title="Open the <%= h(team['name']) %> page">
                  <% if team['image_url'] && !team['image_url'].to_s.empty? %>
                    <img class="sports-standings-team-logo" src="<%= h(team['image_url']) %>" alt="" loading="lazy">
                  <% end %>
                  <span><%= h(team['short_name'] || team['name']) %></span>
                  <% if followed %><span class="sports-standings-follow-mark" title="You follow this team">★</span><% end %>
                </a>
              </td>
              <td class="num"><%= row['wins']  || '—' %></td>
              <td class="num"><%= row['losses'] || '—' %></td>
              <% if rows.any? { |r| r['ties'] && r['ties'].to_i > 0 } %>
                <td class="num"><%= row['ties'] || 0 %></td>
              <% end %>
              <td class="num"><%= row['win_percent'].to_s.empty? ? '—' : row['win_percent'] %></td>
              <td class="num"><%= row['points_for']     || '—' %></td>
              <td class="num"><%= row['points_against'] || '—' %></td>
              <td class="num <%= row['point_differential'].to_i.positive? ? 'positive' : (row['point_differential'].to_i.negative? ? 'negative' : '') %>">
                <%= row['point_differential'] ? (row['point_differential'].to_i.positive? ? "+#{row['point_differential']}" : row['point_differential']) : '—' %>
              </td>
              <td class="<%= row['streak'].to_s.start_with?('W') ? 'positive' : (row['streak'].to_s.start_with?('L') ? 'negative' : '') %>">
                <%= row['streak'].to_s.empty? ? '—' : row['streak'] %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
<% end %>

<%# STUFF #73 — Wikipedia summary. Renders only when the league
    has a wikipedia_title in the catalog AND the fetch succeeded.
    Cached on the row for 24h; the route handler calls refresh
    on demand. %>
<% if @wikipedia && @wikipedia['extract'].to_s != '' %>
  <section class="sports-league-wikipedia" aria-label="About this competition">
    <h3>About</h3>
    <div class="sports-league-wikipedia-body">
      <% if @wikipedia['thumbnail_url'] && !@wikipedia['thumbnail_url'].to_s.empty? %>
        <img class="sports-league-wikipedia-thumb"
             src="<%= h(@wikipedia['thumbnail_url']) %>"
             alt="" loading="lazy">
      <% end %>
      <div class="sports-league-wikipedia-text">
        <p><%= h(@wikipedia['extract']) %></p>
        <% if @wikipedia['page_url'] %>
          <p class="subtitle">
            <a href="<%= h(@wikipedia['page_url']) %>" target="_blank" rel="noopener noreferrer">
              Read on Wikipedia &rarr;
            </a>
          </p>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# STUFF #70 follow-up — fixtures + results via sync.
    Cards adapt per sport: tennis = player rows, F1 = race card,
    team sports = home vs away with logos. %>
<% sport_emoji = @sport ? @sport[:emoji] : '🏟' %>
<% if (@upcoming_matches || []).any? %>
  <section class="benchmark-section">
    <h3>Upcoming fixtures</h3>
    <ul class="sport-match-list">
      <% @upcoming_matches.each do |m| %>
        <%= match_card_html(m, @league['sport'], @teams_by_id || {}, upcoming: true, sport_emoji: sport_emoji) %>
      <% end %>
    </ul>
  </section>
<% end %>

<% if (@recent_finals || []).any? %>
  <section class="benchmark-section">
    <%# Round grouping: tennis + F1. Flat list for season sports. %>
    <% if @results_by_round %>
      <%
        round_order = {
          'Final' => 0, 'Semifinal' => 1, 'Quarterfinal' => 2,
          'Round of 16' => 3, 'Round of 32' => 4, 'Round of 64' => 5,
          'Round of 128' => 6, 'Round 1' => 7, 'Round 2' => 8,
          'Round 3' => 9, 'Round 4' => 10
        }
        build_rounds = ->(matches) {
          by_round = matches.group_by { |m| m['period'].to_s.split('|').first.to_s }
          sorted   = by_round.keys.sort_by { |r| [round_order[r] || 99, r] }
          main     = sorted.reject { |r| r.downcase.include?('qualifying') }
          qual     = sorted.select { |r| r.downcase.include?('qualifying') }
          [by_round, main + qual]
        }
        render_rounds = ->(rounds_hash, display_list) {
          display_list.each do |round_name|
            matches = rounds_hash[round_name]
        %>
            <details <%= 'open' if (round_order[round_name] || 99) <= 2 %>>
              <summary class="sports-round-summary">
                <%= h(round_name.empty? ? 'Other' : round_name) %>
                <span class="muted">(<%= matches.length %>)</span>
              </summary>
              <ul class="sport-match-list">
                <% matches.each do |m| %>
                  <%= match_card_html(m, @league['sport'], @teams_by_id || {}, sport_emoji: sport_emoji) %>
                <% end %>
              </ul>
            </details>
        <%  end
        }
      %>

      <%# Current year first (open), historical collapsed below. %>
      <% if @show_year_split %>
        <details open>
          <summary><h3 style="display:inline"><%= Date.today.year %> Results</h3>
            <span class="muted" style="font-size:0.85rem; margin-left:0.5rem">
              <%= @finals_this_year.count %> matches
            </span>
          </summary>
          <% current_rounds, current_display = build_rounds.(@finals_this_year) %>
          <% render_rounds.(current_rounds, current_display) %>
        </details>
        <details style="margin-top:1rem">
          <summary class="sports-round-summary" style="font-size:1rem; font-weight:700">
            Previous year's results
            <span class="muted" style="font-weight:400; font-size:0.85rem; margin-left:0.4rem">
              <%= @finals_historical.count %> matches
            </span>
          </summary>
          <% hist_rounds, hist_display = build_rounds.(@finals_historical) %>
          <% render_rounds.(hist_rounds, hist_display) %>
        </details>
      <% else %>
        <% all_rounds, all_display = build_rounds.(@recent_finals) %>
        <details open>
          <summary><h3 style="display:inline">Results by round</h3>
            <span class="muted" style="font-size:0.85rem; margin-left:0.5rem">
              <%= @recent_finals.count %> matches
            </span>
          </summary>
          <% render_rounds.(all_rounds, all_display) %>
        </details>
      <% end %>

    <% else %>
      <h3>Recent results</h3>
      <ul class="sport-match-list">
        <% @recent_finals.each do |m| %>
          <%= match_card_html(m, @league['sport'], @teams_by_id || {}, sport_emoji: sport_emoji) %>
        <% end %>
      </ul>
    <% end %>
  </section>
<% end %>

<%# Empty state — when standings + fixtures + results are all
    empty (catalog-source tournament, off-season league, never-
    synced league). %>
<% if @standings_groups.empty? && (@upcoming_matches || []).empty? && (@recent_finals || []).empty? %>
  <div class="empty-state">
    <p>
      No live data synced for <strong><%= h(@league['name']) %></strong> yet.
      <% if @league['source_provider'] == 'espn' %>
        Fixtures + standings populate when the tournament is in season — the cron runs hourly.
      <% else %>
        This tournament doesn't have a live-data provider yet — articles mentioning <strong><%= h(@league['name']) %></strong> surface below.
      <% end %>
    </p>
  </div>
<% end %>

<%# Articles from subscribed feeds that mention this league/tournament.
    Populated by FTS phrase MATCH with a 1h TTL cache. %>
<% if (@league_articles || []).any? %>
  <section class="benchmark-section sports-league-articles">
    <h3>📰 Coverage of <%= h(@league['name']) %>
      <span class="muted" style="font-size:0.85rem; font-weight:400">(<%= @league_articles.length %>)</span>
    </h3>
    <ul class="sports-article-list">
      <% @league_articles.each do |article| %>
        <% feed        = (@feeds_by_id || {})[article['feed_id']] %>
        <% summary_row = (@summaries_by_article_id || {})[article['id']] %>
        <% summary     = skim_summary_for(article, summary_row) %>
        <li class="sports-article <%= 'read' if article['read'] == 1 %>">
          <h4 class="sports-article-title">
            <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
          </h4>
          <% unless summary.empty? %>
            <p class="sports-article-summary"><%= h(summary) %></p>
          <% end %>
          <div class="sports-article-meta">
            <% if feed %>
              <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
              <span class="sports-article-meta-sep">&middot;</span>
            <% end %>
            <span title="<%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
            <span class="sports-article-meta-sep">&middot;</span>
            <a class="sports-article-in-app" href="/article/<%= article['uid'] %>">Open →</a>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
