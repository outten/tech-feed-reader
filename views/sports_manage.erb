<%# STUFF #52 — sport-first landing page. Each chip drills into
    /sports/manage/:sport which lists that sport's leagues. The
    full team grid lives one more level deeper at
    /sports/manage/:sport/:league. %>

<div class="page-header">
  <div>
    <h2>Manage sports</h2>
    <p class="subtitle">
      Browse sports → leagues → teams; follow what you care about.
      Follows are per-account; unfollow anytime.
      <% if @followed_slugs.empty? %>
        <span class="muted">You don't follow any teams yet.</span>
      <% else %>
        Currently following <strong><%= @followed_slugs.length %></strong>
        team<%= 's' if @followed_slugs.length != 1 %>.
      <% end %>
    </p>
  </div>
</div>

<ul class="sports-catalog-grid">
  <% @sports.each do |sport_slug, sport| %>
    <%
      league_count = sport[:leagues].length
      women_leagues = sport[:leagues].count { |lg| lg[:women] }
    %>
    <li class="sports-catalog-card">
      <a class="sports-catalog-card-link" href="/sports/manage/<%= h(sport_slug) %>">
        <span class="sports-catalog-emoji" aria-hidden="true"><%= sport[:emoji] %></span>
        <span class="sports-catalog-name"><%= h(sport[:name]) %></span>
        <span class="sports-catalog-meta">
          <%= league_count %> league<%= 's' unless league_count == 1 %>
          <% if women_leagues.positive? %>
            &middot; <%= women_leagues %> women's
          <% end %>
        </span>
        <% if sport[:blurb] %>
          <span class="sports-catalog-blurb"><%= h(sport[:blurb]) %></span>
        <% end %>
      </a>
    </li>
  <% end %>
</ul>
