<%# STUFF #52 — drill-down: teams within a league. This is the
    follow/unfollow surface; the prior /sports/manage flat grid now
    lives at this depth. %>

<div class="page-header">
  <div>
    <p class="subtitle">
      <a href="/sports/manage">All sports</a> /
      <a href="/sports/manage/<%= h(@sport[:slug]) %>"><%= h(@sport[:name]) %></a>
    </p>
    <h2><%= h(@league[:name]) %></h2>
    <p class="subtitle">
      <% if @league[:women] %>
        <span class="sports-catalog-chip women">Women's league</span>
      <% end %>
      <% if @league[:region] && @league[:region] != 'global' %>
        <span class="sports-catalog-chip region"><%= h(@league[:region].tr('-', ' ')) %></span>
      <% end %>
      <% if @league[:source_provider] == 'espn' %>
        <span class="sports-catalog-chip live" title="Live scores + standings from ESPN">Live</span>
      <% end %>
      <% if @league[:blurb] %>
        <span class="muted"><%= h(@league[:blurb]) %></span>
      <% end %>
    </p>
  </div>
</div>

<% if (@league[:teams] || []).empty? %>
  <div class="empty-state">
    <p>No teams listed in the catalog for this league yet.</p>
    <p class="muted">
      Tournament-style competitions (World Cups, regional cups) don't have a
      persistent team roster — participants vary each cycle. Live scores still
      arrive via the league's RSS feeds.
    </p>
  </div>
<% else %>
  <ul class="sports-manage-grid">
    <% @league[:teams].sort_by { |t| t[:name].to_s }.each do |team| %>
      <% followed = @followed_slugs.include?(team[:slug]) %>
      <li class="sports-manage-team <%= 'is-followed' if followed %>">
        <%# STUFF #52.2 — fall back to the sport's emoji (🏈 / 🏀 /
            ⚽ / 🏏 / 🎾 / 🏎️ / 🏸 / 🐎 / ⛳ / 🏉 / ⚾) instead of the
            generic 🏟 stadium glyph. Catalog entries don't carry
            real team logos yet — that's a future Wikipedia/Wikidata
            scrape — but at least each card now reads at-a-glance as
            the right sport. %>
        <% if team[:image_url] && !team[:image_url].empty? %>
          <img src="<%= h(team[:image_url]) %>" alt="" class="sports-manage-logo" loading="lazy">
        <% else %>
          <span class="sports-manage-logo sports-manage-logo-fallback" aria-hidden="true"><%= @sport[:emoji] || '🏟' %></span>
        <% end %>
        <div class="sports-manage-team-info">
          <span class="sports-manage-team-name"><%= h(team[:short_name] || team[:name]) %></span>
          <% if team[:location] && !team[:location].empty? && team[:location] != team[:name] %>
            <span class="muted sports-manage-team-location"><%= h(team[:location]) %></span>
          <% end %>
          <%# STUFF #52 PR3 + #52.1 — notable players. Each chip
              links to /sports/player/{team_slug}-{name_slug}; the
              route's ensure_catalog_player_by_slug helper upserts
              the sports_players row on first click. %>
          <% if (team[:players] || []).any? %>
            <span class="sports-manage-team-players">
              <span class="muted" aria-hidden="true">👤</span>
              <% team[:players].each_with_index do |player_name, idx| %><%= ' · ' if idx.positive? %><a class="sports-manage-player-link" href="/sports/player/<%= h(catalog_player_slug(team[:slug], player_name)) %>"><%= h(player_name) %></a><% end %>
            </span>
          <% end %>
        </div>
        <form method="post" action="/sports/teams/<%= followed ? 'unfollow' : 'follow' %>" class="sports-manage-form js-sports-follow-form">
          <input type="hidden" name="slug" value="<%= h(team[:slug]) %>">
          <input type="hidden" name="return_to" value="/sports/manage/<%= h(@sport[:slug]) %>/<%= h(@league[:slug]) %>">
          <button type="submit"
                  class="<%= followed ? 'btn-secondary' : 'btn-primary' %> sports-manage-toggle <%= 'is-following' if followed %>"
                  data-full-name="<%= h(team[:name]) %>"
                  data-follow-label="+ Follow"
                  data-following-label="✓ Following"
                  title="<%= followed ? 'Stop following' : 'Follow — fetches recent results in the background' %>">
            <%= followed ? '✓ Following' : '+ Follow' %>
          </button>
        </form>
      </li>
    <% end %>
  </ul>
<% end %>

<%# STUFF #52 PR3 — News + podcasts panel. Curated set of RSS feeds
    that cover this league; one click each adds them to the user's
    subscriptions via /sports/feeds/subscribe → FeedsStore.add_for_user. %>
<% if @league_feeds.any? %>
  <section class="sports-league-feeds">
    <h3>News + podcasts</h3>
    <p class="subtitle">
      Subscribe to RSS feeds that cover <strong><%= h(@league[:name]) %></strong>.
      Adds them to your <a href="/feeds">/feeds</a>; manage there.
    </p>
    <ul class="sports-feed-grid">
      <% @league_feeds.each do |feed| %>
        <% subscribed = @subscribed_urls.include?(feed[:url]) %>
        <li class="sports-feed-card <%= 'is-subscribed' if subscribed %>">
          <div class="sports-feed-meta">
            <span class="sports-feed-title"><%= h(feed[:title]) %></span>
            <% if feed[:blurb] %>
              <span class="sports-feed-blurb"><%= h(feed[:blurb]) %></span>
            <% end %>
          </div>
          <% if subscribed %>
            <span class="sports-feed-state" title="Already subscribed">✓ Subscribed</span>
          <% else %>
            <form method="post" action="/sports/feeds/subscribe" class="sports-feed-form">
              <input type="hidden" name="url" value="<%= h(feed[:url]) %>">
              <input type="hidden" name="return_to" value="/sports/manage/<%= h(@sport[:slug]) %>/<%= h(@league[:slug]) %>">
              <button type="submit" class="btn-primary sports-feed-toggle" title="Subscribe to this feed">+ Subscribe</button>
            </form>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
