<%# STUFF #52 — drill-down: teams within a league. This is the
    follow/unfollow surface; the prior /sports/manage flat grid now
    lives at this depth. %>

<div class="page-header">
  <div>
    <p class="subtitle">
      <a href="/sports/manage">All sports</a> /
      <a href="/sports/manage/<%= h(@sport[:slug]) %>"><%= h(@sport[:name]) %></a>
    </p>
    <h2><%= h(@league[:name]) %></h2>
    <p class="subtitle">
      <% if @league[:women] %>
        <span class="sports-catalog-chip women">Women's league</span>
      <% end %>
      <% if @league[:region] && @league[:region] != 'global' %>
        <span class="sports-catalog-chip region"><%= h(@league[:region].tr('-', ' ')) %></span>
      <% end %>
      <% if @league[:source_provider] == 'espn' %>
        <span class="sports-catalog-chip live" title="Live scores + standings from ESPN">Live</span>
      <% end %>
      <% if @league[:blurb] %>
        <span class="muted"><%= h(@league[:blurb]) %></span>
      <% end %>
    </p>
  </div>
</div>

<% if (@league[:teams] || []).empty? %>
  <div class="empty-state">
    <p>No teams listed in the catalog for this league yet.</p>
    <p class="muted">
      Tournament-style competitions (World Cups, regional cups) don't have a
      persistent team roster — participants vary each cycle. Live scores still
      arrive via the league's RSS feeds.
    </p>
  </div>
<% else %>
  <ul class="sports-manage-grid">
    <% @league[:teams].sort_by { |t| t[:name].to_s }.each do |team| %>
      <% followed = @followed_slugs.include?(team[:slug]) %>
      <li class="sports-manage-team <%= 'is-followed' if followed %>">
        <% if team[:image_url] && !team[:image_url].empty? %>
          <img src="<%= h(team[:image_url]) %>" alt="" class="sports-manage-logo" loading="lazy">
        <% else %>
          <span class="sports-manage-logo sports-manage-logo-fallback" aria-hidden="true">🏟</span>
        <% end %>
        <div class="sports-manage-team-info">
          <span class="sports-manage-team-name"><%= h(team[:short_name] || team[:name]) %></span>
          <% if team[:location] && !team[:location].empty? && team[:location] != team[:name] %>
            <span class="muted sports-manage-team-location"><%= h(team[:location]) %></span>
          <% end %>
        </div>
        <form method="post" action="/sports/teams/<%= followed ? 'unfollow' : 'follow' %>" class="sports-manage-form">
          <input type="hidden" name="slug" value="<%= h(team[:slug]) %>">
          <input type="hidden" name="return_to" value="/sports/manage/<%= h(@sport[:slug]) %>/<%= h(@league[:slug]) %>">
          <% if followed %>
            <button type="submit" class="btn-secondary sports-manage-toggle" title="Stop following">✓ Following</button>
          <% else %>
            <button type="submit" class="btn-primary sports-manage-toggle" title="Follow — fetches recent results in the background">+ Follow</button>
          <% end %>
        </form>
      </li>
    <% end %>
  </ul>
<% end %>
