<%# STUFF #52 — drill-down: leagues within a sport. Click a league
    card to drill into its team grid. Women's leagues get a chip
    badge so they're visually called out at this level. %>

<div class="page-header">
  <div>
    <p class="subtitle"><a href="/sports/manage">← All sports</a></p>
    <h2><span aria-hidden="true"><%= @sport[:emoji] %></span> <%= h(@sport[:name]) %></h2>
    <% if @sport[:blurb] %>
      <p class="subtitle"><%= h(@sport[:blurb]) %></p>
    <% end %>
  </div>
</div>

<%# STUFF #54 — tennis is an individuals-not-teams sport, so the
    natural follow surface is the /sports/tennis rankings page, not
    a team grid. Callout sends the user there. %>
<% if @sport[:slug] == 'tennis' %>
  <div class="sports-manage-action-callout">
    <p>
      <strong>Follow tennis players on the rankings page.</strong>
      The ATP and WTA rankings let you star individual players (Sinner, Świątek, Alcaraz, …)
      so their matches surface across the rest of the app.
    </p>
    <a href="/sports/tennis" class="btn-primary">🎾 Browse rankings &amp; follow players →</a>
  </div>
<% end %>

<%
  # STUFF #70 — split leagues into season-format (ongoing professional
  # play — NFL, NBA, MLS, ATP) and tournament-format (event-shaped —
  # World Cups, Grand Slams). Two separate sections so the user sees
  # the right verbs (drill-down for seasons, ★ Follow for tournaments).
  seasons     = @sport[:leagues].reject { |lg| lg[:format] == :tournament }
  tournaments = @sport[:leagues].select { |lg| lg[:format] == :tournament }
%>

<% if seasons.any? %>
  <% if tournaments.any? %><h3 class="sports-section-heading">Leagues</h3><% end %>
  <ul class="sports-catalog-grid">
    <% seasons.each do |league| %>
      <%
        team_count = (league[:teams] || []).length
        followed_in_league = (league[:teams] || []).count { |t| @followed_slugs.include?(t[:slug]) }
        card_href = if @sport[:slug] == 'tennis'
                      "/sports/tennis#tour-#{league[:slug]}"
                    else
                      "/sports/manage/#{@sport[:slug]}/#{league[:slug]}"
                    end
      %>
      <li class="sports-catalog-card <%= 'is-womens' if league[:women] %>">
        <a class="sports-catalog-card-link" href="<%= h(card_href) %>">
          <span class="sports-catalog-name"><%= h(league[:name]) %></span>
          <span class="sports-catalog-chips">
            <% if league[:women] %>
              <span class="sports-catalog-chip women">Women's</span>
            <% end %>
            <% if league[:region] && league[:region] != 'global' %>
              <span class="sports-catalog-chip region"><%= h(league[:region].tr('-', ' ')) %></span>
            <% end %>
            <% if league[:source_provider] == 'espn' %>
              <span class="sports-catalog-chip live" title="Live scores + standings from ESPN">Live</span>
            <% end %>
          </span>
          <span class="sports-catalog-meta">
            <% if @sport[:slug] == 'tennis' %>
              🎾 Browse rankings &amp; follow players &rarr;
            <% else %>
              <%= team_count %> team<%= 's' unless team_count == 1 %>
              <% if followed_in_league.positive? %>
                &middot; <strong><%= followed_in_league %> followed</strong>
              <% end %>
            <% end %>
          </span>
          <% if league[:blurb] %>
            <span class="sports-catalog-blurb"><%= h(league[:blurb]) %></span>
          <% end %>
        </a>
      </li>
    <% end %>
  </ul>
<% end %>

<% if tournaments.any? %>
  <%# STUFF #70 — tournament cards. Don't drill into a team grid
      (tournaments don't carry a stable team list). Instead each
      card has an inline ★ Follow toggle. Following adds the
      league to sports_follows.kind='league' and lazy-upserts the
      sports_leagues row from catalog. %>
  <h3 class="sports-section-heading">📅 Tournaments</h3>
  <p class="subtitle sports-section-subtitle">
    Subscribe to a tournament to surface its articles on /sports
    and (where ESPN data is available) its standings + matches.
  </p>
  <ul class="sports-catalog-grid">
    <% tournaments.each do |tour| %>
      <%
        followed = @followed_league_slugs.include?(tour[:slug])
      %>
      <li class="sports-catalog-card sports-tournament-card <%= 'is-followed' if followed %> <%= 'is-womens' if tour[:women] %>">
        <span class="sports-catalog-name"><%= h(tour[:name]) %></span>
        <span class="sports-catalog-chips">
          <% if tour[:women] %>
            <span class="sports-catalog-chip women">Women's</span>
          <% end %>
          <% if tour[:country] %>
            <span class="sports-catalog-chip region"><%= h(tour[:country]) %></span>
          <% end %>
          <% if tour[:source_provider] == 'espn' %>
            <span class="sports-catalog-chip live" title="Live standings + scores from ESPN">Live</span>
          <% end %>
        </span>
        <% if tour[:blurb] %>
          <span class="sports-catalog-blurb"><%= h(tour[:blurb]) %></span>
        <% end %>
        <form method="post" action="/sports/leagues/<%= followed ? 'unfollow' : 'follow' %>" class="sports-manage-form js-sports-follow-form">
          <input type="hidden" name="slug" value="<%= h(tour[:slug]) %>">
          <input type="hidden" name="return_to" value="/sports/manage/<%= h(@sport[:slug]) %>">
          <button type="submit"
                  class="<%= followed ? 'btn-secondary' : 'btn-primary' %> sports-manage-toggle <%= 'is-following' if followed %>"
                  title="<%= followed ? 'Stop following' : 'Follow — surfaces tournament articles on /sports' %>">
            <%= followed ? '✓ Following' : '+ Follow' %>
          </button>
        </form>
      </li>
    <% end %>
  </ul>
<% end %>
