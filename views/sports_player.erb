<div class="page-header sports-player-header">
  <div>
    <h2>
      <% if @player['headshot_url'] && !@player['headshot_url'].to_s.empty? %>
        <img class="sports-player-headshot" src="<%= h(@player['headshot_url']) %>" alt="" loading="lazy">
      <% end %>
      <%= h(@player['full_name']) %>
    </h2>
    <p class="subtitle">
      <% if @player['tour'] %>
        <%# Tennis (ESPN-synced) %>
        <% if @player['flag_url'] && !@player['flag_url'].to_s.empty? %>
          <img class="sports-tennis-flag" src="<%= h(@player['flag_url']) %>" alt="" loading="lazy">
        <% end %>
        <%= h(@player['country'] || '—') %>
        &middot; <strong><%= h(@player['tour'].to_s.upcase) %></strong>
        &middot; <a href="/sports/tennis">&larr; All rankings</a>
      <% elsif @catalog_team %>
        <%# STUFF #52.1 — catalog player (notable-player chip on a
            team card). Surface the team + back-link to manage. %>
        Notable player on
        <strong><%= h(@catalog_team[:name]) %></strong>
        &middot; <%= h((@player['sport'] || '').capitalize) %>
        &middot; <a href="/sports/manage/<%= h(@catalog_team[:sport_slug]) %>/<%= h(@catalog_team[:league_slug]) %>">&larr; <%= h(@catalog_team[:name]) %> team page</a>
      <% else %>
        <%= h(@player['country'] || '—') %>
        &middot; <a href="/sports">&larr; Sports</a>
      <% end %>
    </p>
  </div>
</div>

<% if @player['tour'] %>
  <%# Tennis stat cards. Catalog players (non-tennis) don't have
      ranking data, so the cards stay hidden — the Articles +
      Follow + About sections are enough. %>
  <div class="stat-cards sports-player-stats">
    <div class="summary-card">
      <span class="summary-label">Current rank</span>
      <span class="summary-value"><%= @player['current_rank'] || '—' %></span>
      <% if @player['previous_rank'] && @player['current_rank'] %>
        <% diff = @player['previous_rank'].to_i - @player['current_rank'].to_i %>
        <span class="summary-sub <%= diff > 0 ? 'positive' : (diff < 0 ? 'negative' : '') %>">
          <% if diff > 0 %>
            &uarr; <%= diff %> from <%= @player['previous_rank'] %>
          <% elsif diff < 0 %>
            &darr; <%= diff.abs %> from <%= @player['previous_rank'] %>
          <% else %>
            unchanged
          <% end %>
        </span>
      <% end %>
    </div>
    <div class="summary-card">
      <span class="summary-label">Points</span>
      <span class="summary-value"><%= @player['points'] ? @player['points'].to_i : '—' %></span>
      <span class="summary-sub muted">tour ranking points</span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Tour</span>
      <span class="summary-value"><%= h(@player['tour'].to_s.upcase) %></span>
      <span class="summary-sub muted">
        <%= @player['tour'] == 'atp' ? "men's tour" : "women's tour" %>
      </span>
    </div>
  </div>
<% end %>

<section class="benchmark-section sports-player-follow" style="margin-top:1.5rem">
  <h3><%= @is_followed ? '★ Followed' : '☆ Not followed' %></h3>
  <p class="subtitle">
    <% if @is_followed %>
      You're following <%= h(@player['full_name']) %>
      <% if @player['tour'] %>
        — they appear at the top of <a href="/sports/tennis">/sports/tennis</a>.
      <% else %>
        — articles mentioning them surface below.
      <% end %>
    <% else %>
      <% if @player['tour'] %>
        Follow to surface them at the top of the rankings page.
      <% else %>
        Follow to track articles mentioning <%= h(@player['full_name']) %>.
      <% end %>
    <% end %>
  </p>
  <form method="post" action="/sports/players/<%= @is_followed ? 'unfollow' : 'follow' %>" class="js-sports-follow-form">
    <input type="hidden" name="slug" value="<%= h(@player['slug']) %>">
    <input type="hidden" name="return_to" value="/sports/player/<%= h(@player['slug']) %>">
    <button type="submit"
            class="btn-primary <%= 'is-followed' if @is_followed %>"
            data-full-name="<%= h(@player['full_name']) %>"
            data-follow-label="☆ Follow <%= h(@player['full_name']) %>"
            data-following-label="★ Unfollow <%= h(@player['full_name']) %>">
      <%= @is_followed ? "★ Unfollow #{@player['full_name']}" : "☆ Follow #{@player['full_name']}" %>
    </button>
  </form>
</section>

<% if @espn_url %>
  <section class="benchmark-section" style="margin-top:1.5rem">
    <h3>External profile</h3>
    <p class="subtitle">
      Detailed match results, head-to-heads, and career stats live on ESPN — opens in a new tab.
    </p>
    <p>
      <a class="btn-primary" href="<%= h(@espn_url) %>" target="_blank" rel="noopener noreferrer">
        Open <%= h(@player['full_name']) %> on ESPN &rarr;
      </a>
    </p>
  </section>
<% end %>

<%# S7 follow-up #2 — articles mentioning this player. FTS5 phrase
    cache populated by SportsEntityArticlesStore on page load (TTL 1h). %>
<section class="benchmark-section sports-entity-articles" style="margin-top:1.5rem">
  <h3>
    Articles mentioning <%= h(@player['full_name']) %>
    <span class="muted" style="font-size:0.85rem; font-weight:normal">
      (<%= (@related_articles || []).length %>)
    </span>
  </h3>
  <% if (@related_articles || []).empty? %>
    <p class="muted">No articles mentioning <%= h(@player['full_name']) %> in your feeds yet. New matches surface here as articles are imported.</p>
  <% else %>
    <ul class="sports-article-list">
      <% @related_articles.each do |article| %>
        <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
        <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
        <% summary_text = skim_summary_for(article, summary_row) %>
        <li class="sports-article <%= 'read' if article['read'] == 1 %>">
          <h4 class="sports-article-title">
            <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
          </h4>
          <% unless summary_text.empty? %>
            <p class="sports-article-summary"><%= h(summary_text) %></p>
          <% end %>
          <div class="sports-article-meta">
            <% if feed %>
              <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
              <span class="sports-article-meta-sep">&middot;</span>
            <% end %>
            <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>

<section class="benchmark-section" style="margin-top:1.5rem">
  <h3>About</h3>
  <dl class="sports-player-about">
    <% if @player['country'] %><dt>Country</dt><dd><%= h(@player['country']) %></dd><% end %>
    <dt>Last synced</dt>
    <dd><%= @player['last_synced_at'] ? relative_time(@player['last_synced_at']) : '—' %></dd>
  </dl>
</section>
