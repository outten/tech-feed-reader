<%# STUFF #67 — leaner team detail page for DB-side teams not in the
    curated SportsTeams Ruby module (FIFA World Cup countries, every
    NFL team besides Eagles, every NBA team besides Sixers, etc.).
    Mirrors the curated sports_team.erb but drops the curated-only
    sections (per-team RSS feeds, hand-written blurb, emoji): just
    name + logo + league + standings + fixtures + results + mentions. %>

<%
  is_tennis_player = @league && @league['sport'] == 'tennis'
  ext_id = @team_row['external_id'].to_s
  headshot_url = if is_tennis_player && !ext_id.empty? && @team_row['image_url'].to_s.empty?
    "https://a.espncdn.com/i/headshots/tennis/players/full/#{ext_id}.png"
  end
  logo_url = @team_row['image_url'].to_s.empty? ? headshot_url : @team_row['image_url']
  sport_emoji = begin
    @league ? (SportsCatalog.find_sport(@league['sport'])&.dig(:emoji) || '🏟') : '🏟'
  rescue
    '🏟'
  end
%>
<div class="page-header sports-team-header">
  <div>
    <h2>
      <% if logo_url %>
        <% if headshot_url %>
          <%# Tennis player headshot: circular avatar style %>
          <span class="tennis-match-avatar" style="width:52px;height:52px;display:inline-flex;vertical-align:middle;margin-right:0.4rem">
            <img src="<%= h(logo_url) %>" alt="" loading="lazy" onerror="this.style.display='none'">
            <span class="tennis-match-initials" style="font-size:1rem">
              <%= @team_row['name'].split.map { |w| w[0] }.first(2).join.upcase %>
            </span>
          </span>
        <% else %>
          <img class="sports-team-logo" src="<%= h(logo_url) %>" alt="" loading="lazy">
        <% end %>
      <% end %>
      <%= h(@team_row['name']) %>
    </h2>
    <p class="subtitle">
      <% if @league %>
        <% if is_tennis_player %>
          <span class="sports-catalog-chip">🎾 Player</span>
          &middot;
          <a href="/sports/league/<%= h(@league['slug']) %>">
            <%= h(@league['name']) %> draw →
          </a>
        <% else %>
          <a href="/sports/league/<%= h(@league['slug']) %>"><%= h(@league['name']) %></a>
        <% end %>
        &middot;
      <% end %>
      <a href="/sports">&larr; All sports</a>
    </p>
    <% if @standings %>
      <p class="subtitle sports-team-standing">
        <% if @standings['group_name'] %>
          <strong><%= h(@standings['group_name']) %></strong> &middot;
        <% end %>
        <%= @standings['position'] || '—' %><% if @standings['position'] %><sup><%= position_suffix(@standings['position'].to_i) %></sup><% end %>
        <% if @standings['wins'] && @standings['losses'] %>
          (<%= @standings['wins'] %>&ndash;<%= @standings['losses'] %><% if @standings['ties'].to_i > 0 %>&ndash;<%= @standings['ties'] %><% end %>)
        <% end %>
        <% if @standings['streak'] && !@standings['streak'].to_s.empty? %>
          &middot; <span class="<%= @standings['streak'].start_with?('W') ? 'positive' : 'negative' %>">streak <%= h(@standings['streak']) %></span>
        <% end %>
        <% if @league %>
          &middot; <a href="/sports/league/<%= h(@league['slug']) %>">Full standings &rarr;</a>
        <% end %>
      </p>
    <% end %>
  </div>
  <%# Follow / unfollow toggle. Mirrors the curated team page button.
      Action targets the existing /sports/teams/{follow,unfollow}
      endpoints (which accept slug in the POST body + a return_to). %>
  <form class="sports-follow-form" method="post"
        action="/sports/teams/<%= @followed ? 'unfollow' : 'follow' %>"
        data-follow-toggle data-kind="team" data-value="<%= h(@team_row['slug']) %>">
    <input type="hidden" name="slug" value="<%= h(@team_row['slug']) %>">
    <input type="hidden" name="return_to" value="/sports/team/<%= h(@team_row['slug']) %>">
    <button type="submit" class="btn-secondary sports-follow-btn <%= 'is-followed' if @followed %>"
            title="<%= @followed ? 'Stop following' : 'Follow this team' %>">
      <% if @followed %>★ Following<% else %>☆ Follow<% end %>
    </button>
  </form>
</div>

<%# Upcoming fixtures. Renders nothing if the team has no scheduled
    matches in the table (off-season, or league not synced yet). %>
<% if @upcoming.any? %>
  <section class="benchmark-section">
    <h3><%= is_tennis_player ? 'Next match' : 'Upcoming fixtures' %></h3>
    <ul class="sport-match-list">
      <% @upcoming.each do |m| %>
        <%= match_card_html(m, @league ? @league['sport'] : 'team',
                            @teams_by_id || {}, upcoming: true, sport_emoji: sport_emoji) %>
      <% end %>
    </ul>
  </section>
<% end %>

<% if @recent_finals.any? %>
  <section class="benchmark-section">
    <h3><%= is_tennis_player ? 'Tournament results' : 'Recent results' %></h3>
    <ul class="sport-match-list">
      <% @recent_finals.each do |m| %>
        <%= match_card_html(m, @league ? @league['sport'] : 'team',
                            @teams_by_id || {}, sport_emoji: sport_emoji) %>
      <% end %>
    </ul>
  </section>
<% end %>

<%# Articles mentioning this team — bridges sports_entity_articles
    populated by FTS5 phrase MATCH on the team name. Often empty for
    international/lower-profile teams where the user has no relevant
    feed subscribed; the empty-state nudges them toward subscribing. %>
<% if @mentions.any? %>
  <section class="benchmark-section">
    <h3>📰 Mentions of <%= h(@team_row['name']) %></h3>
    <ul class="sports-article-list">
      <% @mentions.each do |a| %>
        <li class="sports-article">
          <h4 class="sports-article-title">
            <a href="/article/<%= h(a['uid']) %>"><%= h(a['title']) %></a>
          </h4>
          <div class="sports-article-meta">
            <span title="Published <%= h(a['published_at']) %>"><%= relative_time(a['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# Empty-state for teams with no fixtures, results, or articles —
    typical between tournaments. %>
<% if @upcoming.empty? && @recent_finals.empty? && @mentions.empty? %>
  <div class="empty-state">
    <p>
      No fixtures, results, or articles for <strong><%= h(@team_row['name']) %></strong> yet.
      <% if @league %>
        Pages fill in once the <%= h(@league['name']) %> sync runs
        (<code>make sync-sports</code>); during the tournament window
        the schedule, scores, and standings populate automatically.
      <% end %>
      Subscribe to a relevant feed at <a href="/feeds">/feeds</a> if you
      want article coverage too.
    </p>
  </div>
<% end %>
