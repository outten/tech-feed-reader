<div class="page-header">
  <div>
    <h2>🎾 Tennis rankings</h2>
    <p class="subtitle">
      Top <%= @limit %> on each tour (ATP + WTA), updated daily by <code>make sync-sports</code>.
      &middot; <a href="/sports">&larr; All sports</a>
      <% latest = (@atp + @wta).map { |p| p['last_synced_at'] }.compact.max %>
      <% if latest %>&middot; updated <%= relative_time(latest) %><% end %>
    </p>
  </div>
</div>

<%# Phase S7 follow-up — followed-players callout. Only renders
    when the user has at least one ★. Click a row → player detail. %>
<% if (@followed_players || []).any? %>
  <section class="benchmark-section sports-tennis-followed" style="margin-bottom:1.5rem">
    <h3>★ My followed players <span class="muted" style="font-size:0.85rem; font-weight:normal">(<%= @followed_players.length %>)</span></h3>
    <ul class="sports-tennis-followed-list">
      <% @followed_players.sort_by { |p| p['current_rank'].to_i.zero? ? 99_999 : p['current_rank'].to_i }.each do |p| %>
        <li class="sports-tennis-followed-row">
          <% if p['headshot_url'] && !p['headshot_url'].to_s.empty? %>
            <img class="sports-tennis-followed-photo" src="<%= h(p['headshot_url']) %>" alt="" loading="lazy">
          <% end %>
          <a class="sports-tennis-name" href="/sports/player/<%= h(p['slug']) %>"><%= h(p['full_name']) %></a>
          <span class="muted">
            #<%= p['current_rank'] || '—' %>
            <% if p['tour'] %>· <%= h(p['tour'].upcase) %><% end %>
            <% if p['country'] %>· <%= h(p['country']) %><% end %>
          </span>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<% if @atp.empty? && @wta.empty? %>
  <div class="empty-state">
    <p><strong>No tennis rankings yet.</strong></p>
    <p class="muted">
      ESPN's rankings endpoint may have timed out or returned no
      entries. Reload to retry — every page load triggers a refresh
      if the cached data is older than 12 hours.
    </p>
  </div>
<% else %>
  <div class="sports-tennis-grid">
    <% [
      ['ATP', "men's tour",   @atp, 'atp'],
      ['WTA', "women's tour", @wta, 'wta']
    ].each do |label, gender, rows, tour_slug| %>
      <section class="benchmark-section sports-tennis-tour">
        <h3 class="sports-tennis-heading"><%= label %> &mdash; <%= gender %></h3>
        <% if rows.empty? %>
          <p class="muted">No <%= label %> rankings synced yet.</p>
        <% else %>
          <table class="data-table sports-tennis-table">
            <thead>
              <tr>
                <th class="sports-tennis-rank">#</th>
                <th></th>
                <th>Player</th>
                <th>Country</th>
                <th class="num">Points</th>
                <th>Trend</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% rows.each do |p| %>
                <% diff = (p['previous_rank'].to_i - p['current_rank'].to_i) %>
                <tr>
                  <td class="sports-tennis-rank"><%= p['current_rank'] %></td>
                  <td class="sports-tennis-photo">
                    <% if p['headshot_url'] && !p['headshot_url'].to_s.empty? %>
                      <img src="<%= h(p['headshot_url']) %>" alt="" loading="lazy">
                    <% end %>
                  </td>
                  <td>
                    <a class="sports-tennis-name" href="/sports/player/<%= h(p['slug']) %>"
                       title="Open <%= h(p['full_name']) %> profile"><%= h(p['full_name']) %></a>
                  </td>
                  <td class="sports-tennis-country">
                    <% if p['flag_url'] && !p['flag_url'].to_s.empty? %>
                      <img class="sports-tennis-flag" src="<%= h(p['flag_url']) %>" alt="" loading="lazy">
                    <% end %>
                    <span class="muted"><%= h(p['country'] || '—') %></span>
                  </td>
                  <td class="num"><%= p['points'] ? p['points'].to_i : '—' %></td>
                  <td class="<%= diff > 0 ? 'positive' : (diff < 0 ? 'negative' : 'muted') %>">
                    <% if diff > 0 %>
                      &uarr; <%= diff %>
                    <% elsif diff < 0 %>
                      &darr; <%= diff.abs %>
                    <% else %>
                      &mdash;
                    <% end %>
                  </td>
                  <td class="sports-tennis-follow-cell">
                    <% followed = (@followed_player_slugs || []).include?(p['slug']) %>
                    <form method="post" action="/sports/players/<%= followed ? 'unfollow' : 'follow' %>" style="display:inline">
                      <input type="hidden" name="slug" value="<%= h(p['slug']) %>">
                      <input type="hidden" name="return_to" value="/sports/tennis">
                      <button type="submit"
                              class="sports-tennis-follow-btn <%= 'is-followed' if followed %>"
                              title="<%= followed ? "Unfollow #{p['full_name']}" : "Follow #{p['full_name']}" %>"
                              aria-label="<%= followed ? 'Unfollow' : 'Follow' %> <%= h(p['full_name']) %>">
                        <%= followed ? '★' : '☆' %>
                      </button>
                    </form>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </section>
    <% end %>
  </div>
<% end %>
