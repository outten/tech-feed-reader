<div class="page-header">
  <div>
    <h2>Tags</h2>
    <p class="subtitle">
      Rule-based tagging. Each rule auto-applies on import; adding a rule
      runs a one-time backfill against existing articles.
      <%= @tags.length %> tag<%= 's' unless @tags.length == 1 %>.
    </p>
  </div>
</div>

<% if @notice == 'added' %>
  <div class="notice">
    Tag added.
    <% if (params['tagged'] || '0') != '0' %>
      <%= h(params['tagged']) %> existing article<%= 's' unless params['tagged'] == '1' %> tagged via backfill.
    <% end %>
  </div>
<% elsif @notice == 'removed' %>
  <div class="notice">Tag removed.</div>
<% end %>

<% if @error == 'missing-fields' %>
  <div class="error">Name and match value are required.</div>
<% elsif @error == 'invalid-kind' %>
  <div class="error">match_kind must be one of: regex, keyword, feed_id.</div>
<% elsif @error == 'invalid-regex' %>
  <div class="error">That regex didn't compile.</div>
<% elsif @error == 'duplicate-name' %>
  <div class="error">A tag with that name already exists.</div>
<% elsif @error == 'not-found' %>
  <div class="error">No tag with that id.</div>
<% end %>

<div class="portfolio-add">
  <h3>Add a tag rule</h3>
  <form method="post" action="/tags" class="portfolio-form">
    <label>
      Name
      <input type="text" name="name" required placeholder="e.g. ai, rust, hn">
    </label>
    <label>
      Match kind
      <select name="match_kind">
        <option value="keyword">keyword</option>
        <option value="regex">regex</option>
        <option value="feed_id">feed_id</option>
      </select>
    </label>
    <label>
      Match value
      <input type="text" name="match_value" required placeholder="word, regex, or feed id">
    </label>
    <button type="submit" class="btn-primary">Add rule</button>
  </form>
  <p class="subtitle" style="margin-top:0.75rem">
    <strong>keyword</strong>: case-insensitive substring against title + content.
    <strong>regex</strong>: Ruby regex source, case-insensitive.
    <strong>feed_id</strong>: every article from a specific feed (find ids on
    <a href="/feeds">/feeds</a>).
  </p>
</div>

<% if @tags.any? %>
  <table class="data-table" style="margin-top:2rem">
    <thead>
      <tr><th>Tag</th><th>Kind</th><th>Match value</th><th>Articles</th><th></th></tr>
    </thead>
    <tbody>
      <% @tags.each do |tag| %>
        <tr>
          <td><a class="tag-chip" href="/articles?tag=<%= tag['id'] %>"><%= h(tag['name']) %></a></td>
          <td class="muted"><%= tag['match_kind'] %></td>
          <td>
            <% if tag['match_kind'] == 'feed_id' && (feed = @feeds_by_id[tag['match_value'].to_i]) %>
              <%= h(feed['title'] || feed['url']) %> <span class="muted">(id <%= tag['match_value'] %>)</span>
            <% else %>
              <code><%= h(tag['match_value']) %></code>
            <% end %>
          </td>
          <td class="num"><%= @article_counts[tag['id']] || 0 %></td>
          <td>
            <form method="post" action="/tags/<%= tag['id'] %>/delete" style="display:inline" onsubmit="return confirm('Remove this tag and all its associations?');">
              <button type="submit" class="danger">Remove</button>
            </form>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
