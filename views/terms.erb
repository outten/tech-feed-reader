<%# Public terms-of-use page. Plain-language, matched to a small
    consumer reader app. Not legal advice; review by counsel before
    relying on it for anything serious. %>

<div class="page-header">
  <div>
    <h2>Terms of Use</h2>
    <p class="subtitle">
      Last updated: <%= File.mtime(__FILE__).strftime('%B %-d, %Y') %>
