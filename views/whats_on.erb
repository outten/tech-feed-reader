<%# STUFF.md #17 — What's On Today.
    Personalized one-page surface for "what should I do with this app
    today." Pulls from data we already track and filters to today's
    rows, ranked / followed / scoped by user preference. %>

<div class="page-header">
  <div>
    <h2>What's On Today</h2>
    <p class="subtitle">
      <%= Time.now.strftime('%A, %B %-d, %Y') %>
      &middot; Sports fixtures, top picks, and new content from your follows + feeds.
    </p>
  </div>
</div>

<% if @nothing_today %>
  <div class="empty-state">
    <p><strong>Quiet day.</strong> Nothing new from your followed teams or feeds yet.</p>
    <p class="muted">
      <a href="/articles?sort=relevance&amp;state=unread">Browse your unread queue &rarr;</a>
      &middot;
      <a href="/feeds">Add more feeds &rarr;</a>
    </p>
  </div>
<% end %>

<% if (@today_matches || []).any? %>
  <section class="benchmark-section whats-on-section">
    <h3>🏟 Sports today <span class="muted whats-on-count">(<%= @today_matches.length %>)</span></h3>
    <ul class="whats-on-matches">
      <% @today_matches.each do |match| %>
        <% home = (@teams_by_id || {})[match['home_team_id']] %>
        <% away = (@teams_by_id || {})[match['away_team_id']] %>
        <% league = (@leagues_by_id || {})[match['league_id']] %>
        <li class="whats-on-match">
          <span class="whats-on-time">
            <% if match['scheduled_at'] %>
              <%= Time.parse(match['scheduled_at']).getlocal.strftime('%-l:%M %p') rescue match['scheduled_at'] %>
            <% else %>
              TBD
            <% end %>
          </span>
          <span class="whats-on-matchup">
            <% if away %><a href="/sports/team/<%= h(away['slug']) %>"><%= h(away['short_name'] || away['name']) %></a><% else %>—<% end %>
            <span class="muted">@</span>
            <% if home %><a href="/sports/team/<%= h(home['slug']) %>"><%= h(home['short_name'] || home['name']) %></a><% else %>—<% end %>
          </span>
          <% if league %>
            <span class="muted whats-on-league"><%= h(league['name']) %></span>
          <% end %>
          <% if match['status'].to_s == 'live' %>
            <span class="badge live-badge" title="Match is live now">LIVE</span>
          <% end %>
        </li>
      <% end %>
    </ul>
    <p class="subtitle whats-on-foot">
      <a href="/sports/calendar">Full calendar (next 30 days) &rarr;</a>
    </p>
  </section>
<% end %>

<% if (@today_reading || []).any? %>
  <section class="benchmark-section whats-on-section">
    <h3>📰 To read today <span class="muted whats-on-count">(<%= @today_reading.length %>)</span></h3>
    <ul class="sports-article-list">
      <% @today_reading.each do |article| %>
        <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
        <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
        <% summary_text = skim_summary_for(article, summary_row) %>
        <li class="sports-article <%= 'read' if article['read'] == 1 %>">
          <h4 class="sports-article-title">
            <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
          </h4>
          <% unless summary_text.empty? %>
            <p class="sports-article-summary"><%= h(summary_text) %></p>
          <% end %>
          <div class="sports-article-meta">
            <% if feed %>
              <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
              <span class="sports-article-meta-sep">&middot;</span>
            <% end %>
            <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>
    <p class="subtitle whats-on-foot">
      <a href="/articles?sort=relevance&amp;state=unread">Full For You queue &rarr;</a>
    </p>
  </section>
<% end %>

<% if (@today_listening || []).any? %>
  <section class="benchmark-section whats-on-section">
    <h3>🎧 To listen today <span class="muted whats-on-count">(<%= @today_listening.length %>)</span></h3>
    <ul class="sports-article-list">
      <% @today_listening.each do |article| %>
        <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
        <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
        <% summary_text = skim_summary_for(article, summary_row) %>
        <li class="sports-article <%= 'read' if article['read'] == 1 %>">
          <h4 class="sports-article-title">
            <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
            <span class="badge podcast-badge" title="Podcast episode">🎧</span>
          </h4>
          <% unless summary_text.empty? %>
            <p class="sports-article-summary"><%= h(summary_text) %></p>
          <% end %>
          <div class="sports-article-meta">
            <% if feed %>
              <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
              <span class="sports-article-meta-sep">&middot;</span>
            <% end %>
            <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
          </div>
        </li>
      <% end %>
    </ul>
    <p class="subtitle whats-on-foot">
      <a href="/podcasts">All podcasts &rarr;</a>
    </p>
  </section>
<% end %>

<% if (@today_watching || []).any? %>
  <section class="benchmark-section whats-on-section">
    <h3>📺 To watch today <span class="muted whats-on-count">(<%= @today_watching.length %>)</span></h3>
    <ul class="sports-article-list whats-on-watch">
      <% @today_watching.each do |article| %>
        <% feed         = (@feeds_by_id || {})[article['feed_id']] %>
        <% summary_row  = (@summaries_by_article_id || {})[article['id']] %>
        <% summary_text = skim_summary_for(article, summary_row) %>
        <% thumb        = youtube_thumbnail_url(article) %>
        <li class="sports-article whats-on-watch-card <%= 'read' if article['read'] == 1 %>">
          <% if thumb %>
            <a class="whats-on-watch-thumb" href="/article/<%= article['uid'] %>"
               title="Play <%= h(article['title']) %> in app">
              <img src="<%= h(thumb) %>" alt="" loading="lazy">
              <span class="whats-on-watch-play" aria-hidden="true">▶</span>
            </a>
          <% end %>
          <div class="whats-on-watch-body">
            <h4 class="sports-article-title">
              <a href="/article/<%= article['uid'] %>"><%= h(article['title']) %></a>
            </h4>
            <% unless summary_text.empty? %>
              <p class="sports-article-summary"><%= h(summary_text) %></p>
            <% end %>
            <div class="sports-article-meta">
              <% if feed %>
                <a class="sports-article-source" href="/articles?feed_id=<%= feed['id'] %>"><%= h(feed['title'] || feed['url']) %></a>
                <span class="sports-article-meta-sep">&middot;</span>
              <% end %>
              <span title="Published <%= h(article['published_at']) %>"><%= relative_time(article['published_at']) %></span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
    <p class="subtitle whats-on-foot">
      <a href="/articles?topic=nature">All nature feeds &rarr;</a>
    </p>
  </section>
<% end %>
